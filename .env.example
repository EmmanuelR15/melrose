# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Instagram Basic Display API (Optional)
PUBLIC_INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# Google Analytics 4 (Optional)
PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# WhatsApp Business Configuration
PUBLIC_WHATSAPP_NUMBER=5491123456789

# Environment
NODE_ENV=development

# Site Configuration
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=MELROSE Streetwear
PUBLIC_SITE_DESCRIPTION=Tienda e-commerce de streetwear con diseño único

# Social Media Links
PUBLIC_INSTAGRAM_URL=https://instagram.com/melrose.stw
PUBLIC_FACEBOOK_URL=https://facebook.com/melrose.streetwear

# Currency and Locale
PUBLIC_CURRENCY=ARS
PUBLIC_LOCALE=es-AR

# Feature Flags
PUBLIC_INSTAGRAM_FEED_ENABLED=true
PUBLIC_ANALYTICS_ENABLED=true
PUBLIC_WHATSAPP_CHECKOUT_ENABLED=true
