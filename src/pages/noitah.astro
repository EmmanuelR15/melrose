---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Check if already logged in
const isAdmin = Astro.cookies.get('admin_token')?.value === 'melrose_admin_2024';

let products = [];
if (isAdmin) {
  const fallbackProducts = [
    {
      id: 'fallback-1',
      nombre: 'URBAN TEE CLASSIC',
      precio: 45000,
      imagen_url: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop',
      categoria: 'REMERAS',
      stock: 15
    },
    {
      id: 'fallback-2',
      nombre: 'STREET HOODIE PRO',
      precio: 78000,
      imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
      categoria: 'BUZOS',
      stock: 8
    }
  ];

  try {
    if (supabase) {
      const { data, error } = await supabase
        .from('productos')
        .select('*')
        .order('created_at', { ascending: false });
      
      products = error ? [] : data ?? fallbackProducts;
    } else {
      products = fallbackProducts;
    }
  } catch (err) {
    products = fallbackProducts;
  }
}
---

<Layout title={isAdmin ? "Admin Panel | MELROSE" : "Access Control | MELROSE"}>
  {isAdmin ? (
    <main class="admin-panel">
      <div class="container">
        <div class="admin-header">
          <h1>PANEL DE ADMINISTRACIÓN</h1>
          <p>Gestión de productos y inventario</p>
          <a href="/" class="back-to-site">Volver al sitio</a>
          <button id="logoutBtn" class="btn-logout">Cerrar Sesión</button>
        </div>

        <div class="admin-content">
          <section class="product-management">
            <h2>Gestión de Productos</h2>
            
            <div class="product-form">
              <h3>Agregar/Editar Producto</h3>
              <form id="productForm">
                <div class="form-grid">
                  <div class="form-group">
                    <label for="productId">ID del Producto</label>
                    <input type="text" id="productId" name="id" placeholder="Auto-generado" readonly>
                  </div>
                  
                  <div class="form-group">
                    <label for="productName">Nombre *</label>
                    <input type="text" id="productName" name="nombre" required>
                  </div>
                  
                  <div class="form-group">
                    <label for="productPrice">Precio (ARS) *</label>
                    <input type="number" id="productPrice" name="precio" min="0" step="100" required>
                  </div>
                  
                  <div class="form-group">
                    <label for="productCategory">Categoría *</label>
                    <div class="category-input-wrapper">
                      <select id="productCategory" name="categoria" required>
                        <option value="">Cargando categorías...</option>
                      </select>
                      <button type="button" id="addCategoryBtn" class="btn-add-mini" title="Agregar nueva categoría">+</button>
                    </div>
                  </div>
                  
                  <div class="form-group">
                    <label for="productStock">Stock *</label>
                    <input type="number" id="productStock" name="stock" min="0" step="1" required>
                  </div>
                  
                  <div class="form-group full-width">
                    <label>Talles Disponibles</label>
                    <div class="talles-grid">
                      {['S', 'M', 'L', 'XL', 'XXL', 'Talle Único'].map(talle => (
                        <label class="checkbox-label talle-checkbox">
                          <input type="checkbox" name="talles" value={talle}>
                          <span class="checkbox-custom"></span>
                          {talle}
                        </label>
                      ))}
                    </div>
                  </div>
                  
                  <div class="form-group checkbox-group">
                    <label for="productFeatured" class="checkbox-label">
                      <input type="checkbox" id="productFeatured" name="destacado" value="true">
                      <span class="checkbox-custom"></span>
                      Marcar como Destacado
                    </label>
                  </div>
                  
                  <div class="form-group full-width">
                    <label for="productImage">Imagen del Producto</label>
                    <div class="image-upload-container">
                      <input type="file" id="imageUpload" accept="image/png, image/jpeg, image/webp">
                      <input type="hidden" id="productImage" name="imagen_url">
                      <div id="imagePreview" class="image-preview-mini"></div>
                    </div>
                    <small class="form-help">Las imágenes se guardan localmente. Límite de 5MB por producto.</small>
                  </div>
                  
                  <div class="form-group full-width">
                    <label for="productDescription">Descripción</label>
                    <textarea id="productDescription" name="descripcion" rows="3"></textarea>
                  </div>
                </div>
                
                <div class="form-actions">
                  <button type="submit" class="btn-primary">Guardar Producto</button>
                  <button type="button" id="clearForm" class="btn-secondary">Limpiar Formulario</button>
                </div>
              </form>
            </div>

            <div class="products-list">
              <h3>Productos Existentes</h3>
              {products.length > 0 ? (
                <div class="products-table">
                <table>
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Nombre</th>
                      <th>Precio</th>
                      <th>Categoría</th>
                      <th>Stock</th>
                      <th>Destacado</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    {products.map((product) => (
                      <tr data-product-id={product.id}>
                        <td data-label="ID">{product.id}</td>
                        <td data-label="Nombre">{product.nombre}</td>
                        <td data-label="Precio">${product.precio.toLocaleString('es-AR')}</td>
                        <td data-label="Categoría">{product.categoria}</td>
                        <td data-label="Stock">{product.stock}</td>
                        <td data-label="Destacado" class="featured-cell">
                          {product.destacado ? <span class="featured-star">⭐</span> : <span class="not-featured">-</span>}
                        </td>
                        <td data-label="Acciones">
                          <button class="btn-edit" data-product-id={product.id}>Editar</button>
                          <button class="btn-delete" data-product-id={product.id}>Eliminar</button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              ) : (
                <div class="empty-state">
                  <p>No hay productos cargados aún</p>
                </div>
              )}
            </div>
          </section>

          <section class="admin-stats">
            <h2>Estadísticas Rápidas</h2>
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-icon">📦</div>
                <div class="stat-content">
                  <h3>Total Productos</h3>
                  <p class="stat-number">{products.length}</p>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">💰</div>
                <div class="stat-content">
                  <h3>Valor del Inventario</h3>
                  <p class="stat-number">
                    {products.reduce((sum, p) => sum + (p.precio * (p.stock || 0)), 0).toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })}
                  </p>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">📈</div>
                <div class="stat-content">
                  <h3>Producto Más Caro</h3>
                  <p class="stat-number">
                    ${products.length > 0 
                      ? Math.max(...products.map(p => p.precio)).toLocaleString('es-AR')
                      : '0'
                    }
                  </p>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">📉</div>
                <div class="stat-content">
                  <h3>Producto Más Barato</h3>
                  <p class="stat-number">
                    ${products.length > 0 
                      ? Math.min(...products.map(p => p.precio)).toLocaleString('es-AR')
                      : '0'
                    }
                  </p>
                </div>
              </div>
              <div class="stat-card">
                <div class="stat-icon">📊</div>
                <div class="stat-content">
                  <h3>Precio Promedio</h3>
                  <p class="stat-number">
                    ${products.length > 0 
                      ? Math.round(products.reduce((sum, p) => sum + p.precio, 0) / products.length).toLocaleString('es-AR')
                      : '0'
                    }
                  </p>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
  ) : (
    <main class="admin-login">
      <div class="login-container">
        <div class="login-card">
          <div class="login-header">
            <h1>ACCESS CONTROL</h1>
            <p>Authorized personnel only</p>
          </div>

          <form id="loginForm" class="login-form">
            <div class="form-group">
              <input 
                type="password" 
                id="password" 
                name="password" 
                required
                placeholder="Enter credentials"
                autocomplete="off"
              >
            </div>
            
            <button type="submit" class="login-btn">
              AUTHENTICATE
            </button>
          </form>

          <div class="login-footer">
            <a href="/" class="back-link">Return to site</a>
          </div>
        </div>
      </div>
    </main>
  )}
</Layout>

<script>
  import { gsap } from 'gsap';
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // Shared Admin Logic (Login & Panel)
  
  // Anti-intrusion for login mode (REMOVED TO PREVENT ACCIDENTAL REDIRECTS)
  /*
  if (!document.querySelector('.admin-panel')) {
    (function() {
      console.clear();
      console.log('%c🚫 Unauthorized access prohibited', 'color: red; font-size: 20px; font-weight: bold;');
      let devtools = { open: false, orientation: null };
      const threshold = 160;
      setInterval(() => {
        if (window.outerHeight - window.innerHeight > threshold || window.outerWidth - window.innerWidth > threshold) {
          if (!devtools.open) {
            devtools.open = true;
            document.body.innerHTML = '<div style="display: flex; justify-content: center; align-items: center; height: 100vh; background: #0a0a0a; color: #f5f5f5; font-family: monospace; font-size: 24px;">🚫 Access Denied</div>';
            window.location.href = '/';
          }
        } else {
          devtools.open = false;
        }
      }, 500);
      document.addEventListener('contextmenu', e => e.preventDefault());
      document.addEventListener('keydown', e => {
        if (e.keyCode === 123 || (e.ctrlKey && e.shiftKey && (e.keyCode === 73 || e.keyCode === 74)) || (e.ctrlKey && e.keyCode === 85)) {
          e.preventDefault(); return false;
        }
      });
    })();
  }
  */

  // SHA-256
  async function sha256(message) {
    const msgBuffer = new TextEncoder().encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  async function compressImage(file, maxWidth = 1500, quality = 0.85) {
    return new Promise((resolve) => {
      const img = new Image();
      const url = URL.createObjectURL(file);
      img.onload = () => {
        const scale = Math.min(1, maxWidth / img.width);
        const canvas = document.createElement('canvas');
        canvas.width = img.width * scale;
        canvas.height = img.height * scale;
        const ctx = canvas.getContext('2d');
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        canvas.toBlob((blob) => {
          URL.revokeObjectURL(url);
          resolve(new File([blob], file.name.replace(/\.[^.]+$/, '.jpg'), { type: 'image/jpeg' }));
        }, 'image/jpeg', quality);
      };
      img.src = url;
    });
  }

  document.addEventListener('DOMContentLoaded', async () => {
    // Session Sync: Si hay cookie pero no sessionStorage, sincronizar.
    const getCookie = (name) => {
      const value = `; ${document.cookie}`;
      const parts = value.split(`; ${name}=`);
      if (parts.length === 2) return parts.pop().split(';').shift();
    };

    const adminCookie = getCookie('admin_token');
    if (adminCookie === 'melrose_admin_2024' && !sessionStorage.getItem('admin_session_token')) {
      console.log('🔄 [DEBUG] Sincronizando sesión desde cookie a sessionStorage...');
      sessionStorage.setItem('admin_session_token', 'melrose_admin_2024');
    }

    console.log('🔍 [DEBUG] Script de administración cargado');
    console.log('🍪 [DEBUG] Cookie actual:', document.cookie);
    console.log('📂 [DEBUG] SessionStorage token:', sessionStorage.getItem('admin_session_token'));

    const loginForm = document.getElementById('loginForm');
    
    if (loginForm) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const password = e.target.password.value;
        const hashedPassword = await sha256('melrose_admin_2024');
        const inputHash = await sha256(password);
        
        if (inputHash === hashedPassword) {
          console.log('✅ [DEBUG] Password correcto. Seteando sesión...');
          sessionStorage.setItem('admin_session_token', 'melrose_admin_2024');
          document.cookie = 'admin_token=melrose_admin_2024; path=/; max-age=86400; SameSite=Lax';
          console.log('🔄 [DEBUG] Recargando página...');
          window.location.reload(); 
        } else {
          const errorDiv = document.createElement('div');
          errorDiv.className = 'login-error';
          errorDiv.textContent = 'Authentication failed';
          errorDiv.style.cssText = 'color: var(--rojo); margin-top: 1rem; text-align: center; font-weight: 600; opacity: 0; transform: translateY(-10px); transition: all 0.3s ease;';
          const existingError = loginForm.querySelector('.login-error');
          if (existingError) existingError.remove();
          loginForm.appendChild(errorDiv);
          setTimeout(() => { errorDiv.style.opacity = '1'; errorDiv.style.transform = 'translateY(0)'; }, 100);
          e.target.password.value = '';
          setTimeout(() => {
            if (errorDiv.parentNode) {
              errorDiv.style.opacity = '0';
              errorDiv.style.transform = 'translateY(-10px)';
              setTimeout(() => errorDiv.remove(), 300);
            }
          }, 3000);
        }
      });
    }

    // Panel logic
    if (document.querySelector('.admin-panel')) {
      const sessionToken = sessionStorage.getItem('admin_session_token');
      if (!sessionToken || sessionToken !== 'melrose_admin_2024') {
        console.error('❌ [DEBUG] Fallo de validación de sesión, pero evito redirigir para debugear.');
        console.log('   Expected: melrose_admin_2024');
        console.log('   Found:', sessionToken);
        // window.location.href = '/';
        return;
      }

      const logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', () => {
          // 1. Limpiar Storage
          localStorage.clear();
          sessionStorage.clear();
          
          // 2. Limpiar Cookie con expiración nuclear
          document.cookie = "admin_token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; SameSite=Lax";
          
          console.log("☢️ Cierre de sesión nuclear completado");
          
          // 3. Redirigir y reemplazar historial
          window.location.replace('/');
        });
      }

      const form = document.getElementById('productForm');
      const clearBtn = document.getElementById('clearForm');
      const addCategoryBtn = document.getElementById('addCategoryBtn');
      const productCategorySelect = document.getElementById('productCategory');
      const editBtns = document.querySelectorAll('.btn-edit');
      const deleteBtns = document.querySelectorAll('.btn-delete');
      const imageUpload = document.getElementById('imageUpload');
      const imagePreview = document.getElementById('imagePreview');
      const productImageInput = document.getElementById('productImage');
      let currentEditId = null;
      
      async function fetchCategorias() {
        if (!supabase) return;
        try {
          const { data, error } = await supabase.from('categorias').select('*').order('nombre');
          if (error) throw error;
          
          if (productCategorySelect) {
            productCategorySelect.innerHTML = '<option value="">Seleccionar categoría...</option>';
            data.forEach(cat => {
              const option = document.createElement('option');
              option.value = cat.nombre;
              option.textContent = cat.nombre;
              productCategorySelect.appendChild(option);
            });
          }
        } catch (err) {
          console.error("Error fetching categories:", err);
          if (productCategorySelect) productCategorySelect.innerHTML = '<option value="">Error al cargar</option>';
        }
      }

      async function addCategory() {
        const nombre = prompt("Ingrese el nombre de la nueva categoría:");
        if (!nombre || !supabase) return;
        
        try {
          const { error } = await supabase.from('categorias').insert([{ nombre }]);
          if (error) throw error;
          alert("Categoría añadida exitosamente");
          await fetchCategorias();
        } catch (err) {
          alert("Error al añadir categoría: " + err.message);
        }
      }

      if (addCategoryBtn) addCategoryBtn.addEventListener('click', addCategory);

      function handleImageUpload(e) {
        const file = e.target.files[0];
        if (!file) return;
        
        // Removed strict 5MB alert as we will compress it on submission
        if (file.size > 5 * 1024 * 1024) {
          console.log('📸 Imagen pesada detectada, se optimizará al subir.');
        }
        const reader = new FileReader();
        reader.onload = (event) => {
          imagePreview.innerHTML = `<img src="${event.target.result}" alt="Preview">`;
        };
        reader.readAsDataURL(file);
      }

      if (imageUpload) imageUpload.addEventListener('change', handleImageUpload);
      
      function clearForm() { 
        form.reset(); 
        document.getElementById('productId').value = ''; 
        productImageInput.value = '';
        imagePreview.innerHTML = '';
        currentEditId = null; 
      }
      
      async function editProduct(productId) {
        try {
          const { data: product, error } = await supabase
            .from('productos')
            .select('*')
            .eq('id', productId)
            .single();
          
          if (error) throw error;
          if (!product) return;

          document.getElementById('productId').value = product.id;
          document.getElementById('productName').value = product.nombre;
          document.getElementById('productPrice').value = product.precio;
          document.getElementById('productCategory').value = product.categoria;
          document.getElementById('productStock').value = product.stock;
          
          // Imagen
          productImageInput.value = product.imagen_url || '';
          if (product.imagen_url) {
            imagePreview.innerHTML = `<img src="${product.imagen_url}" alt="Preview">`;
          } else {
            imagePreview.innerHTML = '';
          }
          
          // Talles
          const selectedTalles = Array.isArray(product.talles) ? product.talles : (product.talles ? product.talles.split(',') : []);
          const checkboxes = form.querySelectorAll('input[name="talles"]');
          checkboxes.forEach(cb => {
            cb.checked = selectedTalles.includes(cb.value);
          });
          
          document.getElementById('productDescription').value = product.descripcion || '';
          document.getElementById('productFeatured').checked = product.destacado || false;
          currentEditId = productId;
          
          form.scrollIntoView({ behavior: 'smooth' });
          gsap.from(form, { backgroundColor: 'rgba(0, 255, 255, 0.05)', duration: 0.5 });
          
        } catch (err) {
          console.error("❌ Error al cargar producto para edición:", err);
          alert("Error al cargar datos del producto");
        }
      }
      
      async function deleteProduct(productId) {
        if (!confirm('¿Estás seguro de eliminar este producto?')) return;
        
        try {
          const { error } = await supabase
            .from('productos')
            .delete()
            .eq('id', productId);
          
          if (error) throw error;
          
          const row = document.querySelector(`tr[data-product-id="${productId}"]`);
          if (row) {
            gsap.to(row, { 
              opacity: 0, 
              x: -20, 
              duration: 0.3, 
              onComplete: () => row.remove() 
            });
          }
          console.log(`✅ Producto ${productId} eliminado de Supabase`);
        } catch (err) {
          console.error("❌ Error al eliminar:", err);
          alert("No se pudo eliminar el producto: " + err.message);
        }
      }
      
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const submitBtn = form.querySelector('button[type="submit"]');
          const originalBtnText = submitBtn.textContent;
          
          submitBtn.disabled = true;
          submitBtn.textContent = 'SUBIENDO...';
          submitBtn.style.opacity = '0.7';

          const formData = new FormData(form);
          
          // Capturar talles seleccionados
          const selectedTalles = Array.from(form.querySelectorAll('input[name="talles"]:checked')).map(cb => cb.value);
          
          let imageUrl = productImageInput.value;
          
          // Debug: Capturar archivo de imagen
          const imageFile = imageUpload.files[0];
          if (imageFile) {
            // Comprimir imagen antes de subir
            const compressedFile = await compressImage(imageFile, 1200, 0.82);
            const fileName = `${Date.now()}-${crypto.randomUUID()}.jpg`;
            const { data: uploadData, error: uploadError } = await supabase.storage
              .from('productos')
              .upload(fileName, compressedFile, { contentType: 'image/jpeg', upsert: false });
            if (uploadError) return alert("Error al subir imagen: " + uploadError.message);
            const { data: urlData } = supabase.storage.from('productos').getPublicUrl(fileName);
            imageUrl = urlData.publicUrl;
          }
          
          const product = {
            nombre: formData.get('nombre'),
            precio: parseFloat(formData.get('precio')),
            categoria: formData.get('categoria'),
            stock: parseInt(formData.get('stock'), 10),
            imagen_url: imageUrl,
            talles: selectedTalles,
            descripcion: formData.get('descripcion') || '',
            destacado: formData.get('destacado') === 'true'
          };
          
          // Si estamos editando, incluimos el ID para el upsert
          if (currentEditId) {
            product.id = currentEditId;
          }

          console.log("📦 Datos a enviar a Supabase:", product);
          
          try {
            const { data, error } = await supabase
              .from('productos')
              .upsert([product])
              .select();

            if (error) throw error;
            
            console.log("🚀 Producto guardado en Supabase:", data);
            alert("Producto guardado exitosamente");
            clearForm();
            setTimeout(() => { window.location.reload(); }, 500);
          } catch (err) {
            console.error("❌ Error al guardar producto:", err);
            alert("Error al guardar en Supabase: " + err.message);
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
            submitBtn.style.opacity = '1';
          }
        });
      }
      
      fetchCategorias();
      
      if (clearBtn) clearBtn.addEventListener('click', clearForm);
      editBtns.forEach(btn => btn.addEventListener('click', () => editProduct(btn.dataset.productId)));
      deleteBtns.forEach(btn => btn.addEventListener('click', () => deleteProduct(btn.dataset.productId)));
    }
  });
</script>

<style>
  /* Login CSS */
  .admin-login {
    min-height: 100vh;
    background: var(--negro);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .admin-login::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at 20% 50%, rgba(192, 57, 43, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(0, 255, 255, 0.05) 0%, transparent 50%);
    pointer-events: none; z-index: 1;
  }
  .login-container { width: 100%; max-width: 400px; position: relative; z-index: 2; }
  .login-card { background: var(--negro-suave); border: 1px solid var(--borde); border-radius: 8px; padding: 3rem 2rem; text-align: center; position: relative; overflow: hidden; }
  .login-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--rojo), transparent); opacity: 0.3; }
  .login-header h1 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.1em; color: var(--blanco); margin-bottom: 0.5rem; text-transform: uppercase; }
  .login-header p { color: var(--gris); margin-bottom: 2rem; font-size: 0.9rem; opacity: 0.8; }
