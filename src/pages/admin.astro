---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Enhanced protection - check for session token in sessionStorage
// Note: This check happens on client-side, not server-side
// We'll implement client-side redirect in the script section

// Load products from database or fallback
let products = [];
const fallbackProducts = [
  {
    id: 'fallback-1',
    nombre: 'URBAN TEE CLASSIC',
    precio: 45000,
    imagen_url: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop',
    categoria: 'REMERAS',
    stock: 15
  },
  {
    id: 'fallback-2',
    nombre: 'STREET HOODIE PRO',
    precio: 78000,
    imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
    categoria: 'BUZOS',
    stock: 8
  }
];

try {
  if (supabase) {
    const { data, error } = await supabase
      .from('productos')
      .select('*')
      .order('created_at', { ascending: false });
    
    products = error ? [] : data ?? fallbackProducts;
  } else {
    products = fallbackProducts;
  }
} catch (err) {
  products = fallbackProducts;
}
---

<Layout title="Admin Panel | MELROSE">
  <main class="admin-panel">
    <div class="container">
      <div class="admin-header">
        <h1>PANEL DE ADMINISTRACIÓN</h1>
        <p>Gestión de productos y inventario</p>
        <a href="/" class="back-to-site">Volver al sitio</a>
      </div>

      <div class="admin-content">
        <!-- Product Management -->
        <section class="product-management">
          <h2>Gestión de Productos</h2>
          
          <!-- Add/Edit Product Form -->
          <div class="product-form">
            <h3>Agregar/Editar Producto</h3>
            <form id="productForm">
              <div class="form-grid">
                <div class="form-group">
                  <label for="productId">ID del Producto</label>
                  <input type="text" id="productId" name="id" placeholder="Auto-generado" readonly>
                </div>
                
                <div class="form-group">
                  <label for="productName">Nombre *</label>
                  <input type="text" id="productName" name="nombre" required>
                </div>
                
                <div class="form-group">
                  <label for="productPrice">Precio (ARS) *</label>
                  <input type="number" id="productPrice" name="precio" min="0" step="100" required>
                </div>
                
                <div class="form-group">
                  <label for="productCategory">Categoría *</label>
                  <select id="productCategory" name="categoria" required>
                    <option value="">Seleccionar...</option>
                    <option value="REMERAS">REMERAS</option>
                    <option value="BUZOS">BUZOS</option>
                    <option value="PANTALONES">PANTALONES</option>
                    <option value="ACCESORIOS">ACCESORIOS</option>
                  </select>
                </div>
                
                <div class="form-group">
                  <label for="productStock">Stock *</label>
                  <input type="number" id="productStock" name="stock" min="0" required>
                </div>
                
                <div class="form-group full-width">
                  <label for="productImage">URL de Imagen</label>
                  <input type="url" id="productImage" name="imagen_url" placeholder="https://...">
                </div>
                
                <div class="form-group full-width">
                  <label for="productDescription">Descripción</label>
                  <textarea id="productDescription" name="descripcion" rows="3"></textarea>
                </div>
              </div>
              
              <div class="form-actions">
                <button type="submit" class="btn-primary">Guardar Producto</button>
                <button type="button" id="clearForm" class="btn-secondary">Limpiar Formulario</button>
              </div>
            </form>
          </div>

          <!-- Products List -->
          <div class="products-list">
            <h3>Productos Existentes</h3>
            <div class="products-table">
              <table>
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Categoría</th>
                    <th>Stock</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  {products.map((product) => (
                    <tr data-product-id={product.id}>
                      <td>{product.id}</td>
                      <td>{product.nombre}</td>
                      <td>${product.precio.toLocaleString('es-AR')}</td>
                      <td>{product.categoria}</td>
                      <td>{product.stock}</td>
                      <td>
                        <button class="btn-edit" data-product-id={product.id}>Editar</button>
                        <button class="btn-delete" data-product-id={product.id}>Eliminar</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <!-- Quick Stats -->
        <section class="admin-stats">
          <h2>Estadísticas Rápidas</h2>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon">📦</div>
              <div class="stat-content">
                <h3>Total Productos</h3>
                <p class="stat-number">{products.length}</p>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">💰</div>
              <div class="stat-content">
                <h3>Valor del Inventario</h3>
                <p class="stat-number">
                  ${products.reduce((sum, p) => sum + (p.precio * (p.stock || 0)), 0).toLocaleString('es-AR', { style: 'currency', currency: 'ARS' })}
                </p>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">⭐</div>
              <div class="stat-content">
                <h3>Producto Más Caro</h3>
                <p class="stat-number">
                  ${products.length > 0 
                    ? Math.max(...products.map(p => p.precio)).toLocaleString('es-AR')
                    : '0'
                  }
                </p>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">📊</div>
              <div class="stat-content">
                <h3>Precio Promedio</h3>
                <p class="stat-number">
                  ${products.length > 0 
                    ? Math.round(products.reduce((sum, p) => sum + p.precio, 0) / products.length).toLocaleString('es-AR')
                    : '0'
                  }
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Admin Panel JavaScript
  document.addEventListener('DOMContentLoaded', () => {
    // Session Guard: Check for valid session token
    const sessionToken = sessionStorage.getItem('admin_session_token');
    if (!sessionToken || sessionToken !== 'melrose_admin_2024') {
      // Redirect to 404-like page to hide admin existence
      window.location.href = '/'; // Redirect to home instead of 404
      return;
    }

    const form = document.getElementById('productForm');
    const clearBtn = document.getElementById('clearForm');
    const editBtns = document.querySelectorAll('.btn-edit');
    const deleteBtns = document.querySelectorAll('.btn-delete');
    
    let currentEditId = null;
    
    // Load products from localStorage fallback
    function loadProducts() {
      const stored = localStorage.getItem('admin_products');
      return stored ? JSON.parse(stored) : [];
    }
    
    function saveProducts(products) {
      localStorage.setItem('admin_products', JSON.stringify(products));
    }
    
    // Clear form
    function clearForm() {
      form.reset();
      document.getElementById('productId').value = '';
      currentEditId = null;
    }
    
    // Edit product
    function editProduct(productId) {
      const products = loadProducts();
      const product = products.find(p => p.id === productId);
      
      if (product) {
        document.getElementById('productId').value = product.id;
        document.getElementById('productName').value = product.nombre;
        document.getElementById('productPrice').value = product.precio;
        document.getElementById('productCategory').value = product.categoria;
        document.getElementById('productStock').value = product.stock;
        document.getElementById('productImage').value = product.imagen_url || '';
        document.getElementById('productDescription').value = product.descripcion || '';
        
        currentEditId = productId;
        
        // Scroll to form
        form.scrollIntoView({ behavior: 'smooth' });
      }
    }
    
    // Delete product
    function deleteProduct(productId) {
      if (confirm('¿Estás seguro de eliminar este producto?')) {
        const products = loadProducts();
        const updatedProducts = products.filter(p => p.id !== productId);
        saveProducts(updatedProducts);
        
        // Remove row from table
        const row = document.querySelector(`tr[data-product-id="${productId}"]`);
        if (row) {
          row.remove();
        }
        
        // Update stats
        updateStats();
      }
    }
    
    // Update statistics
    function updateStats() {
      const products = loadProducts();
      const statNumbers = document.querySelectorAll('.stat-number');
      
      if (statNumbers.length >= 4) {
        statNumbers[0].textContent = products.length;
        statNumbers[1].textContent = products.reduce((sum, p) => sum + (p.stock || 0), 0);
        statNumbers[2].textContent = products.length > 0 
          ? Math.round(products.reduce((sum, p) => sum + p.precio, 0) / products.length).toLocaleString('es-AR')
          : '0';
        statNumbers[3].textContent = [...new Set(products.map(p => p.categoria))].length;
      }
    }
    
    // Form submission
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const product = {
        id: currentEditId || 'product_' + Date.now(),
        nombre: formData.get('nombre'),
        precio: parseFloat(formData.get('precio')),
        categoria: formData.get('categoria'),
        stock: parseInt(formData.get('stock')),
        imagen_url: formData.get('imagen_url') || '',
        descripcion: formData.get('descripcion') || '',
        updated_at: new Date().toISOString()
      };
      
      const products = loadProducts();
      
      if (currentEditId) {
        // Update existing product
        const index = products.findIndex(p => p.id === currentEditId);
        if (index > -1) {
          products[index] = product;
        }
      } else {
        // Add new product
        products.push(product);
      }
      
      saveProducts(products);
      clearForm();
      
      // Refresh page to show updated products
      setTimeout(() => {
        window.location.reload();
      }, 1000);
    });
    
    // Clear button
    clearBtn.addEventListener('click', clearForm);
    
    // Edit buttons
    editBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        editProduct(btn.dataset.productId);
      });
    });
    
    // Delete buttons
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        deleteProduct(btn.dataset.productId);
      });
    });
  });
</script>

<style>
  .admin-panel {
    min-height: 100vh;
    background: var(--negro);
    color: var(--blanco);
    padding: 2rem 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .admin-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--borde);
  }

  .admin-header h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--blanco);
  }

  .admin-header p {
    color: var(--gris);
    margin-bottom: 1.5rem;
  }

  .back-to-site {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--rojo);
    color: var(--blanco);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }

  .back-to-site:hover {
    background: var(--rojo-oscuro);
  }

  .admin-content {
    display: grid;
    gap: 3rem;
  }

  .product-management h2,
  .admin-stats h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    color: var(--blanco);
  }

  .product-form {
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 8px;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .product-form h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--blanco);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full-width {
    grid-column: 1 / -1;
  }

  .form-group label {
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--gris);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.75rem;
    background: var(--negro);
    border: 1px solid var(--borde);
    color: var(--blanco);
    border-radius: 4px;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--rojo);
  }

  .form-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--rojo);
    color: var(--blanco);
  }

  .btn-primary:hover {
    background: var(--rojo-oscuro);
  }

  .btn-secondary {
    background: transparent;
    color: var(--gris);
    border: 1px solid var(--borde);
  }

  .btn-secondary:hover {
    border-color: var(--rojo);
    color: var(--rojo);
  }

  .products-table {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 8px;
    overflow: hidden;
  }

  th,
  td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--borde);
  }

  th {
    background: var(--negro);
    font-weight: 600;
    color: var(--blanco);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  td {
    color: var(--gris);
  }

  .btn-edit,
  .btn-delete {
    padding: 0.25rem 0.75rem;
    border: none;
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
    margin-right: 0.5rem;
    transition: all 0.3s ease;
  }

  .btn-edit {
    background: var(--cyan);
    color: var(--negro);
  }

  .btn-edit:hover {
    background: #00cccc;
  }

  .btn-delete {
    background: var(--rojo);
    color: var(--blanco);
  }

  .btn-delete:hover {
    background: var(--rojo-oscuro);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .stat-card {
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .stat-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .stat-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-card h3 {
    font-size: 0.8rem;
    color: var(--gris);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-number {
    font-size: 1.8rem;
    font-family: 'Bebas Neue', sans-serif;
    color: var(--cyan);
    font-weight: 900;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .form-actions {
      flex-direction: column;
    }
    
    .products-table {
      font-size: 0.8rem;
    }
    
    th,
    td {
      padding: 0.5rem;
    }
  }
</style>
