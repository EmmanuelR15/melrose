---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import ProductCard from '../components/ProductCard.astro';
import { supabase } from '../lib/supabase';

let products = [];

try {
  if (supabase) {
    const { data, error } = await supabase
      .from('productos')
      .select('*')
      .order('created_at', { ascending: false });

    products = error ? [] : data ?? [];
  }
} catch {
  products = [];
}
---

<Layout title="MELROSE | STW">
	<main>
		<Hero />
    
    <Manifesto />

    <section id="productos" class="section-gallery">
      <div class="section-title section-narrow">
        <p class="kicker">Catálogo</p>
        <h2>DROP 01 / 2026</h2>
      </div>

      <div class="products-grid">
        {products.length > 0 ? (
          products.map((product) => (
            <ProductCard product={product} />
          ))
        ) : (
          <p class="empty-message">El catálogo está en mantenimiento. Volvé a cargar la página en unos minutos.</p>
        )}
      </div>
    </section>
	</main>
</Layout>

<style>
	main {
		width: 100%;
	}

  .section-title {
    margin-bottom: 8rem;
    text-align: left;
  }

  .section-title h2 {
    letter-spacing: 0.2em;
  }

  .kicker {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--rojo);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 8rem 4rem;
    padding: 0 8%;
  }

  .empty-message {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1rem;
    color: var(--texto);
    opacity: 0.8;
    margin: 4rem 0;
  }

  /* Editorial Layout: Algunos elementos ocupan ms espacio */
  @media (min-width: 1024px) {
    .products-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12rem 6rem;
    }
    
    .products-grid > :nth-child(odd) {
      width: 90%;
    }
    
    .products-grid > :nth-child(even) {
      width: 100%;
      margin-top: 15rem; /* Escalonado editorial */
    }
  }
</style>
