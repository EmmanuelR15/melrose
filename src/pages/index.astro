---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import Lookbook from '../components/Lookbook.astro';

import About from '../components/About.astro';
import ProductCard from '../components/ProductCard.astro';
import WishlistManager from '../components/WishlistManager.astro';
import { supabase } from '../lib/supabase';

let products = [];
let categories = ['TODO', 'REMERAS', 'BUZOS', 'PANTALONES', 'ACCESORIOS'];

// Load admin products from localStorage (highest priority)
function loadAdminProducts() {
  try {
    const stored = localStorage.getItem('admin_products');
    return stored ? JSON.parse(stored) : null;
  } catch (error) {
    console.error('Error loading admin products:', error);
    return null;
  }
}

// Fallback products with unique placeholder images
const fallbackProducts = [
  {
    id: 'fallback-1',
    nombre: 'URBAN TEE CLASSIC',
    precio: 45000,
    imagen_url: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop',
    categoria: 'REMERAS',
    descripcion: 'Remera clásica urbana con logo bordado',
    stock: 15
  },
  {
    id: 'fallback-2',
    nombre: 'STREET HOODIE PRO',
    precio: 78000,
    imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
    categoria: 'BUZOS',
    descripcion: 'Buzo premium con capucha y bolsillos frontales',
    stock: 8
  },
  {
    id: 'fallback-3',
    nombre: 'CARGO PANTS BLACK',
    precio: 95000,
    imagen_url: 'https://images.unsplash.com/photo-1594633509878-3352ab1d8fd2?w=600&h=800&fit=crop',
    categoria: 'PANTALONES',
    descripcion: 'Pantalón cargo con múltiples bolsillos',
    stock: 12
  },
  {
    id: 'fallback-4',
    nombre: 'URBAN CAP SNAPBACK',
    precio: 35000,
    imagen_url: 'https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=600&h=600&fit=crop',
    categoria: 'ACCESORIOS',
    descripcion: 'Gorra snapback con logo bordado',
    stock: 25
  },
  {
    id: 'fallback-5',
    nombre: 'GRAPHIC TEE LIMITED',
    precio: 52000,
    imagen_url: 'https://images.unsplash.com/photo-1516589218221-68d20a931589?w=600&h=800&fit=crop',
    categoria: 'REMERAS',
    descripcion: 'Remera gráfica edición limitada',
    stock: 10
  },
  {
    id: 'fallback-6',
    nombre: 'ZIPPER HOODIE NAVY',
    precio: 85000,
    imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
    categoria: 'BUZOS',
    descripcion: 'Buzo con cierre frontal y capucha',
    stock: 6
  }
];

// DEBUG: Verificar variables de entorno
console.log('=== SUPABASE DEBUG ===');
console.log('SUPABASE_URL:', import.meta.env.PUBLIC_SUPABASE_URL ? '✅ Configurado' : '❌ NO configurado');
console.log('SUPABASE_KEY:', import.meta.env.PUBLIC_SUPABASE_KEY ? '✅ Configurado' : '❌ NO configurado');
console.log('supabase client:', supabase ? '✅ Cliente creado' : '❌ Cliente NULL');

try {
  if (supabase) {
    const { data, error } = await supabase
      .from('productos')
      .select('*')
      .order('created_at', { ascending: false });

    console.log('Datos recibidos:', data);
    console.log('Error de Supabase:', error);
    console.log('Cantidad de productos:', data?.length ?? 0);

    // Logs temporales adicionales
    console.log('ENV URL:', import.meta.env.PUBLIC_SUPABASE_URL);
    console.log('ENV KEY:', import.meta.env.PUBLIC_SUPABASE_ANON_KEY ? 'OK' : 'MISSING');
    console.log('Supabase client:', supabase ? 'OK' : 'NULL');
    console.log('Productos:', JSON.stringify(products));

    // Priority: 1. Admin localStorage, 2. Supabase, 3. Fallback
    const adminProducts = loadAdminProducts();
    if (adminProducts && adminProducts.length > 0) {
      products = adminProducts;
      console.log('📦 Using admin products from localStorage:', adminProducts.length);
    } else {
      products = error ? [] : data ?? fallbackProducts;
      console.log('📦 Using database/fallback products:', products.length);
    }
  } else {
    console.warn('⚠️ Supabase client no está disponible');
    const adminProducts = loadAdminProducts();
    products = adminProducts || fallbackProducts;
  }
} catch (err) {
  console.error('❌ Error al conectar Supabase:', err);
  const adminProducts = loadAdminProducts();
  products = adminProducts || fallbackProducts;
}
---

<Layout title="MELROSE | EST. 2026">
	<main>
		<Hero />
		<Ticker />
		<FeaturedProducts />
		<Lookbook />

		<About />

		<section id="productos" class="products-section">
			<div class="container">
				<div class="section-header">
					<p class="kicker">CATÁLOGO COMPLETO</p>
					<h2>DROP 01 / 2026</h2>
				</div>

				<div class="filters">
					<button class="filter-btn active" data-filter="TODO">TODO</button>
					{categories.slice(1).map((category) => (
						<button class="filter-btn" data-filter={category}>{category}</button>
					))}
				</div>

				<div class="products-grid">
					{products.length > 0 ? (
						products.map((product) => (
							<ProductCard product={product} client:load />
						))
					) : (
						products.length === 0 ? (
							<div class="fallback-visual">
								<div class="fallback-content">
									<img src="https://images.unsplash.com/photo-1558618047-3c8c5c6910e8?q=80&w=800&auto=format&fit=crop" alt="MELROSE Brand" class="fallback-image" />
									<h3>COLECCIÓN 2026</h3>
									<p>Próximamente disponible en nuestro catálogo oficial</p>
									<a href="https://www.instagram.com/melrose.stw/?hl=es-la" target="_blank" rel="noopener noreferrer" class="btn-primary">
										SEGUIR EN INSTAGRAM @melrose.stw
									</a>
								</div>
							</div>
						) : (
							<div class="no-products">
								<p>No hay productos en esta categoría todavía.</p>
							</div>
						)
					)}
				</div>
			</div>
		</section>
	</main>
	<WishlistManager />
</Layout>

<style>
	main {
		width: 100%;
	}

	.container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.kicker {
		font-size: 0.8rem;
		letter-spacing: 0.3em;
		color: var(--rojo);
		text-transform: uppercase;
		margin-bottom: 1rem;
		font-weight: 600;
	}

	.section-header h2 {
		font-size: clamp(2.5rem, 8vw, 5rem);
		line-height: 1;
		letter-spacing: 0.1em;
		font-family: 'Bebas Neue', sans-serif;
		font-weight: 900;
		color: var(--blanco);
	}

	.filters {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 3rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		background: transparent;
		border: 1px solid var(--borde);
		color: var(--gris);
		padding: 0.5rem 1.5rem;
		font-size: 0.8rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		cursor: pointer;
		transition: all 0.3s ease;
		font-weight: 600;
	}

	.filter-btn:hover,
	.filter-btn.active {
		border-color: var(--rojo);
		color: var(--rojo);
		background: rgba(192, 57, 43, 0.1);
	}

	.products-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-bottom: 6rem;
		min-height: 400px;
	}

	.no-products {
		grid-column: 1 / -1;
		text-align: center;
		padding: 6rem 2rem;
		color: var(--gris);
		font-size: 1rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		min-height: 300px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.fallback-visual {
		grid-column: 1 / -1;
		text-align: center;
		padding: 8rem 2rem;
		min-height: 500px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.fallback-content {
		max-width: 400px;
	}

	.fallback-image {
		width: 100%;
		height: 250px;
		object-fit: cover;
		border-radius: 8px;
		margin-bottom: 2rem;
	}

	.fallback-content h3 {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 2rem;
		letter-spacing: 0.1em;
		color: var(--blanco);
		margin-bottom: 1rem;
	}

	.fallback-content p {
		color: var(--gris);
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.fallback-content .btn-primary {
		background: var(--rojo);
		color: var(--blanco);
		padding: 1rem 2rem;
		border: none;
		border-radius: 6px;
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		cursor: pointer;
		transition: all 0.3s ease;
		text-decoration: none;
		display: inline-block;
	}

	.fallback-content .btn-primary:hover {
		background: var(--rojo-oscuro);
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(192, 57, 43, 0.3);
	}

	@media (max-width: 768px) {
		.products-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.container {
			padding: 0 1rem;
		}

		.section-header {
			margin-bottom: 3rem;
		}

		.filters {
			gap: 0.5rem;
			margin-bottom: 2rem;
		}

		.filter-btn {
			padding: 0.4rem 1rem;
			font-size: 0.7rem;
		}

		.products-grid {
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 1.5rem;
			margin-bottom: 4rem;
		}
	}
</style>

<script>
	// Product filtering functionality
	document.addEventListener('DOMContentLoaded', () => {
		const filterButtons = document.querySelectorAll('.filter-btn');
		const productCards = document.querySelectorAll('.product-card');
		const noProductsMessage = document.querySelector('.no-products');

		// Handle navbar SHOP link with category data
		const shopLink = document.querySelector('a[data-category]');
		if (shopLink) {
			shopLink.addEventListener('click', (e) => {
				e.preventDefault();
				const category = shopLink.dataset.category;
				
				// Scroll to products section
				document.getElementById('productos').scrollIntoView({ behavior: 'smooth' });
				
				// Apply filter after scroll
				setTimeout(() => {
					// Find and click corresponding filter button
					const targetFilter = document.querySelector(`.filter-btn[data-filter="${category}"]`);
					if (targetFilter) {
						targetFilter.click();
					}
				}, 500);
			});
		}

		function updateNoProductsMessage() {
			if (!noProductsMessage) return;
			
			const visibleCards = Array.from(productCards).filter(card => card.style.display !== 'none');
			if (visibleCards.length === 0 && productCards.length > 0) {
				// Show no-products message when filtering results in empty state
				const tempMessage = document.createElement('div');
				tempMessage.className = 'no-products';
				tempMessage.innerHTML = '<p>No hay productos en esta categoría todavía.</p>';
				noProductsMessage.parentNode.appendChild(tempMessage);
				noProductsMessage.style.display = 'none';
			} else if (visibleCards.length > 0) {
				// Hide no-products message when there are visible products
				const tempMessages = document.querySelectorAll('.no-products:not(:first-child)');
				tempMessages.forEach(msg => msg.remove());
				if (noProductsMessage && productCards.length === 0) {
					noProductsMessage.style.display = 'flex';
				}
			}
		}

		filterButtons.forEach(button => {
			button.addEventListener('click', () => {
				// Remove active class from all buttons
				filterButtons.forEach(btn => btn.classList.remove('active'));
				// Add active class to clicked button
				button.classList.add('active');

				const filterValue = button.dataset.filter;

				productCards.forEach((card, index) => {
					const category = card.querySelector('.product-category').textContent.trim();
					const shouldShow = filterValue === 'TODO' || category === filterValue;
					
					if (shouldShow) {
						// Show with animation
						card.style.display = 'block';
						card.style.opacity = '0';
						card.style.transform = 'translateY(20px)';
						
						// Stagger animation
						setTimeout(() => {
							card.style.transition = 'all 0.3s ease';
							card.style.opacity = '1';
							card.style.transform = 'translateY(0)';
						}, index * 50);
					} else {
						// Hide with animation
						card.style.transition = 'all 0.3s ease';
						card.style.opacity = '0';
						card.style.transform = 'translateY(-20px)';
						
						setTimeout(() => {
							card.style.display = 'none';
						}, 300);
					}
				});

				updateNoProductsMessage();
			});
		});
	});
</script>
