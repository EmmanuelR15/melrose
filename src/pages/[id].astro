---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';
import ProductCard from '../components/ProductCard.astro';

export async function getStaticPaths() {
  // Para build-time generation o SSR
  return [];
}

const { id } = Astro.params;

// Obtener producto por ID
let product = null;
let relatedProducts = [];

try {
  if (supabase) {
    // Producto principal
    const { data: productData, error: productError } = await supabase
      .from('productos')
      .select('*')
      .eq('id', id)
      .single();

    if (productError) {
      console.error('Error al obtener producto:', productError);
    } else {
      product = productData;
    }

    // Productos relacionados (misma categoría, solo con stock)
    if (product) {
      const { data: relatedData } = await supabase
        .from('productos')
        .select('*')
        .eq('categoria', product.categoria)
        .neq('id', id)
        .gt('stock', 0) // Solo productos con stock disponible
        .order('created_at', { ascending: false })
        .limit(4);

      relatedProducts = relatedData || [];
    }
  }
} catch (err) {
  console.error('Error:', err);
}

const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});

// URLs de imágenes (asumiendo campo adicional o array)
const productImages = product?.imagenes_url 
  ? product.imagenes_url 
  : product?.imagen_url 
    ? [product.imagen_url] 
    : [];
---

<Layout title={`${product?.nombre || 'Producto'} | MELROSE`}>
  <!-- Dynamic Meta Tags for SEO -->
  <head>
    <meta name="description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbano.`} />
    <meta name="keywords" content={`${product?.nombre}, ${product?.categoria}, streetwear, moda urbana, MELROSE, Argentina, ropa premium`} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="product" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${product?.nombre || 'Producto'} | MELROSE`} />
    <meta property="og:description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbano.`} />
    <meta property="og:image" content={productImages[0]} />
    <meta property="og:image:alt" content={product?.nombre || 'Producto'} />
    <meta property="og:site_name" content="MELROSE" />
    
    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={`${product?.nombre || 'Producto'} | MELROSE`} />
    <meta property="twitter:description" content={product?.descripcion || `Compra ${product?.nombre || 'producto'} en MELROSE. Calidad premium y estilo urbana.`} />
    <meta property="twitter:image" content={productImages[0]} />
    
    <!-- Additional SEO -->
    <link rel="canonical" href={Astro.url} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="MELROSE" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Structured Data for Product -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": product?.nombre || "",
        "description": product?.descripcion || "",
        "image": productImages,
        "category": product?.categoria || "",
        "offers": {
          "@type": "Offer",
          "price": product?.precio || 0,
          "priceCurrency": "ARS",
          "availability": product?.stock > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock"
        },
        "brand": {
          "@type": "Brand",
          "name": "MELROSE"
        }
      })}
    </script>
  </head>

  <main class="product-detail">
    {product ? (
      <>
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <a href="#productos">{product.categoria}</a>
          <span>/</span>
          <span class="current">{product.nombre}</span>
        </nav>

        <!-- Producto Principal -->
        <section class="product-container">
          <div class="product-gallery">
            <div class="main-image">
              <img 
                src={productImages[0]} 
                alt={product.nombre}
                id="mainProductImage"
                loading="eager"
              />
            </div>
            
            {productImages.length > 1 && (
              <div class="thumbnail-grid">
                {productImages.map((img, index) => (
                  <button 
                    class={`thumbnail ${index === 0 ? 'active' : ''}`}
                    onclick={`changeMainImage('${img}')`}
                  >
                    <img src={img} alt={`${product.nombre} ${index + 1}`} />
                  </button>
                ))}
              </div>
            )}
          </div>

          <div class="product-info">
            <div class="product-header">
              <h1>{product.nombre}</h1>
              <p class="category">{product.categoria}</p>
              <div class="price">
                <span class="current">{formatter.format(product.precio)}</span>
              </div>
            </div>

            <div class="product-options">
              <div class="size-selector">
                <label>TALLE</label>
                <select id="sizeSelect">
                  <option value="">Seleccionar talle</option>
                  <option value="XS">XS</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                </select>
              </div>

              <div class="quantity-selector">
                <label>CANTIDAD</label>
                <input 
                  type="number" 
                  id="quantityInput"
                  min="1" 
                  max={product.stock} 
                  value="1" 
                />
              </div>
            </div>

            <div class="product-actions">
              <button 
                class="btn-primary add-to-cart-btn"
                data-id={product.id}
                data-name={product.nombre}
                data-price={product.precio}
                data-stock={product.stock}
                onclick="addToCartFromDetail(this)"
              >
                AGREGAR AL CARRITO
              </button>

              <button 
                class="btn-secondary whatsapp-btn"
                onclick="buyOnWhatsApp({
                  id: '${product.id}',
                  name: '${product.nombre}',
                  price: ${product.precio},
                  quantity: 1
                })"
              >
                COMPRAR POR WHATSAPP
              </button>
            </div>

            <div class="product-description">
              <h3>DESCRIPCIÓN</h3>
              <p>{product.descripcion || 'Producto premium de la colección MELROSE.'}</p>
            </div>

            <div class="product-meta">
              <div class="stock-info">
                <span class={`stock ${product.stock > 0 ? 'available' : 'out'}`}>
                  {product.stock > 0 ? `${product.stock} unidades disponibles` : 'AGOTADO'}
                </span>
              </div>
            </div>
          </div>
        </section>

        {/* Productos Relacionados */}
        {relatedProducts.length > 0 && (
          <section class="related-products">
            <div class="container">
              <div class="section-header">
                <h2>COMBINÁ CON</h2>
                <p>Productos similares que te pueden gustar</p>
              </div>
              <div class="related-products-info">
                <div class="related-products-count">
                  <span>{relatedProducts.length} productos disponibles</span>
                </div>
                <div class="related-products-badge">
                  <span>STOCK DISPONIBLE</span>
                </div>
              </div>
              <div class="products-grid related-grid">
                {relatedProducts.map((relatedProduct) => (
                  <ProductCard product={relatedProduct} client:load />
                ))}
              </div>
              <div class="related-footer">
                <a href="#productos" class="btn-secondary">VER TODO EL CATÁLOGO</a>
                <div class="related-footer-text">
                  <span>o explorá por categorías</span>
                </div>
              </div>
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="not-found">
        <h1>PRODUCTO NO ENCONTRADO</h1>
        <p>El producto que buscas no existe o fue removido.</p>
        <a href="#productos" class="btn-primary">VER CATÁLOGO</a>
      </div>
    )}
  </main>
</Layout>

<script>
  // Cambiar imagen principal
  function changeMainImage(imageSrc) {
    const mainImage = document.getElementById('mainProductImage');
    if (mainImage) {
      mainImage.src = imageSrc;
      
      // Actualizar active thumbnail
      document.querySelectorAll('.thumbnail').forEach(thumb => {
        thumb.classList.remove('active');
      });
      event.target.closest('.thumbnail').classList.add('active');
    }
  }

  // Agregar al carrito desde detalle
  function addToCartFromDetail(button) {
    const sizeSelect = document.getElementById('sizeSelect');
    const quantityInput = document.getElementById('quantityInput');
    
    if (!sizeSelect.value) {
      alert('Por favor selecciona un talle');
      return;
    }

    // Actualizar data attributes con talle y cantidad
    button.dataset.size = sizeSelect.value;
    button.dataset.quantity = quantityInput.value;

    // Disparar evento existente de addToCart
    const cartEvent = new CustomEvent('addToCart', {
      detail: {
        id: button.dataset.id,
        name: button.dataset.name,
        price: parseFloat(button.dataset.price),
        stock: parseInt(button.dataset.stock),
        size: button.dataset.size,
        quantity: parseInt(button.dataset.quantity)
      }
    });
    
    document.dispatchEvent(cartEvent);
  }

  // Compra directa por WhatsApp
  function buyOnWhatsApp(product) {
    const sizeSelect = document.getElementById('sizeSelect');
    const quantityInput = document.getElementById('quantityInput');
    const selectedSize = sizeSelect?.value || 'No seleccionado';
    const selectedQuantity = quantityInput?.value || 1;
    
    const message = `Hola, me gustaría comprar:%0A${product.name} - Talle: ${selectedSize} - Cantidad: ${selectedQuantity}%0APrecio: $ ${(product.price * selectedQuantity).toLocaleString('es-AR')}`;
    window.open(`https://wa.me/5493624645328?text=${encodeURIComponent(message)}`, '_blank');
  }
</script>

<style>
  .product-detail {
    padding: 2rem 0 6rem;
    min-height: 100vh;
  }

  .breadcrumb {
    padding: 1rem 2rem;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--gris);
  }

  .breadcrumb a {
    color: var(--gris);
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: var(--rojo);
  }

  .current {
    color: var(--blanco);
  }

  .product-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .product-gallery {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .main-image img {
    width: 100%;
    height: 600px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .thumbnail-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .thumbnail {
    border: 2px solid transparent;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .thumbnail:hover,
  .thumbnail.active {
    border-color: var(--rojo);
  }

  .thumbnail img {
    width: 100%;
    height: 80px;
    object-fit: cover;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .product-header h1 {
    font-size: 2.5rem;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .category {
    color: var(--gris);
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .price .current {
    font-size: 2rem;
    font-weight: 700;
    color: var(--rojo);
  }

  .product-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .product-options label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gris);
  }

  .product-options select,
  .product-options input {
    width: 100%;
    padding: 0.75rem;
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    color: var(--blanco);
    font-family: inherit;
  }

  .product-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .add-to-cart-btn,
  .whatsapp-btn {
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .add-to-cart-btn {
    background: var(--rojo);
    color: var(--blanco);
    border: none;
  }

  .add-to-cart-btn:hover {
    background: var(--rojo-oscuro);
  }

  .whatsapp-btn {
    background: transparent;
    color: var(--rojo);
    border: 2px solid var(--rojo);
  }

  .whatsapp-btn:hover {
    background: var(--rojo);
    color: var(--blanco);
  }

  .product-description {
    padding: 2rem 0;
    border-top: 1px solid var(--borde);
  }

  .product-description h3 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .stock-info {
    padding: 1rem 0;
    border-top: 1px solid var(--borde);
  }

  .stock.available {
    color: #4CAF50;
  }

  .stock.out {
    color: var(--rojo);
  }

  .not-found {
    text-align: center;
    padding: 6rem 2rem;
  }

  .not-found h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--rojo);
  }

  .related-products {
    padding: 6rem 0;
    background: var(--negro-suave);
    border-top: 1px solid var(--borde);
  }

  .related-products .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .related-products .section-header h2 {
    font-size: 2.5rem;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .product-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1rem;
    }

    .product-gallery {
      position: static;
    }

    .main-image img {
      height: 400px;
    }

    .product-options {
      grid-template-columns: 1fr;
    }

    .product-header h1 {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .related-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .related-products .section-header h2 {
      font-size: 1.8rem;
    }
  }

  .related-products-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .related-products-count {
    text-align: center;
  }

  .related-products-count span {
    color: var(--gris);
    font-size: 0.9rem;
    opacity: 0.8;
    padding: 0.5rem 1rem;
    background: var(--negro);
    border: 1px solid var(--borde);
    border-radius: 20px;
    display: inline-block;
  }

  .related-products-badge {
    text-align: center;
  }

  .related-products-badge span {
    color: var(--blanco);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.8rem;
    background: var(--rojo);
    border: 1px solid var(--rojo);
    border-radius: 15px;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .related-footer {
    text-align: center;
    margin-top: 3rem;
  }

  .related-footer .btn-secondary {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .related-footer-text {
    margin-top: 1rem;
  }

  .related-footer-text span {
    color: var(--gris);
    font-size: 0.85rem;
    opacity: 0.7;
  }
</style>
