---
// Map section with Google Maps embed - dark styled
---

<section class="map-section" id="ubicacion">
  <div class="map-container">
    <div class="map-header">
      <h2>ENCONTRANOS</h2>
    </div>
    <div class="map-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3537!2d-58.3816!3d-34.6037!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzTCsDM2JzEzLjMiUyA1OMKwMjInNTMuOCJX!5e0!3m2!1ses!2sar!4v1"
        width="100%" height="400" style="border:0; filter: grayscale(100%) invert(90%) contrast(90%);" allowfullscreen loading="lazy">
      </iframe>
    </div>
  </div>
</section>

<style>
  .map-section {
    background: var(--negro);
    border-top: 1px solid var(--borde);
    padding: 0;
  }

  .map-container {
    max-width: 100%;
  }

  .map-header {
    text-align: center;
    padding: 4rem 2rem 2rem;
  }

  .map-header h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--blanco);
  }

  .map-wrap {
    width: 100%;
    line-height: 0;
  }

  .map-wrap iframe {
    width: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .map-header {
      padding: 3rem 1rem 1.5rem;
    }

    .map-wrap iframe {
      height: 300px;
    }
  }
</style>
