---
// Lookbook gallery component with Supabase trends integration
import { getTrends } from '../lib/supabase-trends.js';

// Obtener tendencias desde Supabase
const trends = await getTrends(6);

// Fallback estático si no hay tendencias en Supabase
const fallbackTrends = [
  {
    id: 'fallback-1',
    titulo: 'URBAN ESSENTIALS',
    subtitulo: 'Lo básico con actitud',
    imagen_url: 'https://images.unsplash.com/photo-1552902865-b72c031ac5ea?w=800',
    descripcion: 'Piezas fundamentales para el día a día urbano'
  },
  {
    id: 'fallback-2',
    titulo: 'CITY NIGHT',
    subtitulo: 'Estilo nocturno',
    imagen_url: 'https://images.unsplash.com/photo-1509631179647-0177331693ae?w=600',
    descripcion: 'Looks perfectos para salir de noche'
  },
  {
    id: 'fallback-3',
    titulo: 'DEEP COLOR',
    subtitulo: 'Colores intensos',
    imagen_url: 'https://images.unsplash.com/photo-1618354691373-d851c5c3a990?w=400',
    descripcion: 'Paleta de colores profundos y vibrantes'
  },
  {
    id: 'fallback-4',
    titulo: 'CLEAN LINES',
    subtitulo: 'Siluetas limpias',
    imagen_url: 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=600',
    descripcion: 'Líneas puras y minimalistas'
  },
  {
    id: 'fallback-5',
    titulo: 'STREETWEAR PREMIUM',
    subtitulo: 'Alta gama urbana',
    imagen_url: 'https://images.unsplash.com/photo-1583744946564-b52ac1c389c8?w=800',
    descripcion: 'Streetwear con toque premium'
  },
  {
    id: 'fallback-6',
    titulo: 'TEXTURE PLAY',
    subtitulo: 'Juego de texturas',
    imagen_url: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=800',
    descripcion: 'Combinación de texturas interesantes'
  }
];

// Usar tendencias de Supabase si existen, sino usar fallback
const lookbookItems = trends.length > 0 ? trends : fallbackTrends;
---

<section class="lookbook" id="lookbook">
  <div class="container">
    <div class="section-header">
      <h2>LOOKBOOK</h2>
      <p>Estilo urbano, actitud premium</p>
    </div>

    <div class="lookbook-grid">
      {lookbookItems.map((item) => (
        <div class="lookbook-item">
          <img src={item.imagen_url} alt={item.titulo} loading="lazy" />
          <div class="lookbook-overlay">
            <span>{item.titulo}</span>
            {item.subtitulo && <p>{item.subtitulo}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lookbook {
    padding: 4rem 0;
    background: var(--negro);
    border-top: 1px solid var(--borde);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .lookbook-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .lookbook-item {
    height: 220px;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--borde);
    transition: all 0.4s ease;
    cursor: pointer;
  }

  .lookbook-item:hover {
    transform: scale(1.02);
    border-color: var(--rojo);
  }

  .lookbook-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .lookbook-item:hover img {
    transform: scale(1.05);
  }

  .lookbook-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    padding: 2rem 1.5rem 1.5rem;
    color: var(--blanco);
  }

  .lookbook-overlay span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .lookbook {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .lookbook-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .lookbook-item {
      height: 160px;
    }

    .lookbook-overlay {
      padding: 1.5rem 1rem 1rem;
    }

    .lookbook-overlay span {
      font-size: 1rem;
    }
  }
</style>