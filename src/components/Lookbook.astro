---
// Lookbook gallery component with asymmetric urban layout
---

<section class="lookbook" id="lookbook">
  <div class="container">
    <div class="section-header">
      <h2>LOOKBOOK</h2>
      <p>Estilo urbano, actitud premium</p>
    </div>

    <div class="lookbook-grid">
      <div class="lookbook-item large">
        <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=800&auto=format&fit=crop" alt="Urban streetwear look" loading="lazy" />
        <div class="lookbook-overlay">
          <span>URBAN ESSENTIALS</span>
        </div>
      </div>

      <div class="lookbook-item medium">
        <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?q=80&w=600&auto=format&fit=crop" alt="Street style" loading="lazy" />
        <div class="lookbook-overlay">
          <span>CITY NIGHT</span>
        </div>
      </div>

      <div class="lookbook-item small">
        <img src="https://images.unsplash.com/photo-1445205170230-053b83016050?q=80&w=400&auto=format&fit=crop" alt="Premium texture" loading="lazy" />
        <div class="lookbook-overlay">
          <span>DEEP COLOR</span>
        </div>
      </div>

      <div class="lookbook-item medium">
        <img src="https://images.unsplash.com/photo-1506629905607-0b5ab9a9e21a?q=80&w=600&auto=format&fit=crop" alt="Clean silhouettes" loading="lazy" />
        <div class="lookbook-overlay">
          <span>CLEAN LINES</span>
        </div>
      </div>

      <div class="lookbook-item large">
        <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=800&auto=format&fit=crop" alt="Premium streetwear" loading="lazy" />
        <div class="lookbook-overlay">
          <span>STREETWEAR PREMIUM</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lookbook {
    padding: 6rem 0;
    background: var(--negro);
    border-top: 1px solid var(--borde);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .lookbook-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
    height: 600px;
  }

  .lookbook-item {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--borde);
    transition: all 0.4s ease;
    cursor: pointer;
  }

  .lookbook-item:hover {
    transform: scale(1.02);
    border-color: var(--rojo);
  }

  .lookbook-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .lookbook-item:hover img {
    transform: scale(1.05);
  }

  .lookbook-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    padding: 2rem 1.5rem 1.5rem;
    color: var(--blanco);
  }

  .lookbook-overlay span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .large {
    grid-column: 1;
    grid-row: span 2;
  }

  .medium {
    grid-row: span 1;
  }

  .small {
    grid-row: span 1;
  }

  @media (max-width: 768px) {
    .lookbook {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .lookbook-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      height: auto;
      gap: 0.5rem;
    }

    .lookbook-item {
      height: 250px;
    }

    .large {
      grid-column: 1;
      grid-row: span 1;
    }

    .lookbook-overlay {
      padding: 1.5rem 1rem 1rem;
    }

    .lookbook-overlay span {
      font-size: 1rem;
    }
  }
</style>