---
// Carrito interactivo - necesita ser renderizado del lado del cliente
---

<aside class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <h3>TU CARRITO</h3>
    <button class="close-cart" id="closeCart">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer">
    <div class="cart-total">
      <span>TOTAL</span>
      <strong id="cartTotal">$ 0</strong>
    </div>
    <button class="btn-primary checkout-btn" id="checkoutBtn">FINALIZAR COMPRA</button>
  </div>
</aside>

<div class="cart-overlay" id="cartOverlay"></div>

<script type="module">
  // Cart Management Logic
  class CartManager {
    constructor() {
      this.cart = JSON.parse(localStorage.getItem('cart') || '[]');
      this.updateUI();
      this.setupEventListeners();
    }

    setupEventListeners() {
      const cartButton = document.getElementById('cartOpenBtn');
      const closeCart = document.getElementById('closeCart');
      const cartOverlay = document.getElementById('cartOverlay');
      const checkoutBtn = document.getElementById('checkoutBtn');

      cartButton?.addEventListener('click', () => this.toggleCart());
      closeCart?.addEventListener('click', () => this.closeCart());
      cartOverlay?.addEventListener('click', () => this.closeCart());
      checkoutBtn?.addEventListener('click', () => this.checkout());

      // Add to cart buttons
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('btn-agregar') || e.target.classList.contains('add-to-cart')) {
          this.addToCart(e.target);
        }
      });
    }

    addToCart(button) {
      const productId = button.dataset.id;
      const productName = button.dataset.name || 'Producto';
      const productPrice = parseFloat(button.dataset.price) || 0;
      const stock = parseInt(button.dataset.stock) || 0;

      const itemExistente = this.cart.find(i => i.id === productId);
      const cantidadActual = itemExistente ? itemExistente.quantity : 0;

      if (cantidadActual >= stock) {
        alert(`Stock agotado. Solo hay ${stock} unidad/es disponible/s.`);
        return;
      }

      const item = {
        id: productId,
        name: productName,
        price: productPrice,
        stock: stock,
        quantity: 1
      };

      if (itemExistente) {
        itemExistente.quantity++;
      } else {
        this.cart.push(item);
      }

      this.save();
      this.updateUI();
      this.openCart();
    }

    removeFromCart(productId) {
      this.cart = this.cart.filter(p => p.id !== productId);
      this.save();
      this.updateUI();
    }

    updateQuantity(productId, quantity) {
      const item = this.cart.find(p => p.id === productId);
      if (item) {
        const newQty = Math.max(1, Math.min(quantity, item.stock));
        item.quantity = newQty;
        this.save();
        this.updateUI();
      }
    }

    parsePrice(priceStr) {
      return parseFloat(priceStr.replace(/[^\d.-]/g, '')) || 0;
    }

    updateUI() {
      const badge = document.getElementById('cartBadge');
      const itemsContainer = document.getElementById('cartItems');
      const total = document.getElementById('cartTotal');

      if (badge) {
        badge.textContent = this.cart.reduce((sum, item) => sum + item.quantity, 0);
      }

      if (itemsContainer) {
        itemsContainer.innerHTML = this.cart.length
          ? this.cart.map(item => `
              <div class="cart-item">
                <div class="item-info">
                  <h4>${item.name}</h4>
                  <p class="item-price">$ ${item.price.toLocaleString('es-AR')}</p>
                </div>
                <div class="item-controls">
                  <input type="number" value="${item.quantity}" min="1" max="${item.stock}" data-id="${item.id}" class="qty-input">
                  <button class="remove-btn" data-id="${item.id}">Eliminar</button>
                </div>
              </div>
            `).join('')
          : '<p class="empty-cart">Tu carrito está vacío</p>';

        // Add event listeners to quantity inputs and remove buttons
        itemsContainer.querySelectorAll('.qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            this.updateQuantity(e.target.dataset.id, parseInt(e.target.value));
          });
        });

        itemsContainer.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.removeFromCart(e.target.dataset.id);
          });
        });
      }

      if (total) {
        const totalAmount = this.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        total.textContent = `$ ${totalAmount.toLocaleString('es-AR')}`;
      }
    }

    toggleCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.toggle('active');
    }

    openCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.add('active');
    }

    closeCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.remove('active');
    }

    checkout() {
      if (this.cart.length === 0) {
        alert('Tu carrito está vacío');
        return;
      }

      const cartText = this.cart
        .map(item => `${item.name} x${item.quantity} - $ ${(item.price * item.quantity).toLocaleString('es-AR')}`)
        .join('%0A');

      const total = this.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      const message = `Hola, me gustaría comprar:%0A${cartText}%0ATotal: $ ${total.toLocaleString('es-AR')}`;

      window.open(`https://wa.me/5493624645328?text=${encodeURIComponent(message)}`, '_blank');
    }

    save() {
      localStorage.setItem('cart', JSON.stringify(this.cart));
    }
  }

  // Initialize cart on page load
  new CartManager();
</script>

<style>
  .cart-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(3px);
    z-index: 999;
  }

  .cart-overlay.active {
    display: block;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 380px;
    height: 100vh;
    background: var(--negro);
    border-left: 2px solid var(--cyan);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 999;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer.active {
    transform: translateX(0);
  }

  .cart-header {
    padding: 2rem;
    border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0, 212, 255, 0.02);
  }

  .cart-header h3 {
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--cyan);
    text-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
  }

  .close-cart {
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    font-size: 1.2rem;
    cursor: pointer;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
  }

  .close-cart:hover {
    background: var(--cyan);
    color: var(--negro);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
    transform: scale(1.1) rotate(90deg);
  }

  .cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 2rem;
  }

  .cart-item {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(0, 212, 255, 0.1);
    animation: slideIn 0.3s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .item-info h4 {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: var(--blanco);
    font-weight: 700;
  }

  .item-price {
    font-size: 1rem;
    color: var(--cyan);
    font-weight: 600;
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }

  .item-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .qty-input {
    width: 50px;
    padding: 0.5rem;
    background: rgba(0, 212, 255, 0.05);
    border: 1px solid var(--cyan);
    color: var(--blanco);
    text-align: center;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .qty-input:focus {
    outline: none;
    background: rgba(0, 212, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }

  .remove-btn {
    background: transparent;
    border: 1px solid var(--magenta);
    color: var(--magenta);
    padding: 0.5rem 1rem;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    box-shadow: 
      inset 0 0 10px rgba(255, 0, 110, 0.1),
      0 0 10px rgba(255, 0, 110, 0.2);
  }

  .remove-btn:hover {
    background: var(--magenta);
    color: var(--negro);
    box-shadow: 
      0 0 20px rgba(255, 0, 110, 0.6),
      inset 0 0 10px rgba(255, 0, 110, 0.2);
    transform: scale(1.05);
  }

  .empty-cart {
    text-align: center;
    opacity: 0.6;
    font-size: 0.9rem;
    color: var(--gris);
  }

  .cart-footer {
    padding: 2rem;
    border-top: 2px solid rgba(0, 212, 255, 0.2);
    background: rgba(0, 212, 255, 0.02);
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cart-total span {
    color: var(--gris);
  }

  .cart-total strong {
    color: var(--cyan);
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
    font-size: 1.1rem;
  }

  .checkout-btn {
    width: 100%;
  }

  @media (max-width: 768px) {
    .cart-wrapper {
      bottom: 1rem;
      right: 1rem;
    }

    .cart-drawer {
      max-width: 100%;
    }

    @keyframes floatBag {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-5px);
      }
    }
  }
</style>
