---
// Carrito interactivo - necesita ser renderizado del lado del cliente
---

<aside class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <h3>TU CARRITO</h3>
    <button class="close-cart" id="closeCart">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer">
    <div class="cart-total">
      <span>TOTAL</span>
      <strong id="cartTotal">$ 0</strong>
    </div>
    <button class="btn-primary checkout-btn" id="checkoutBtn">FINALIZAR COMPRA</button>
  </div>
</aside>

<div class="cart-overlay" id="cartOverlay"></div>

<script type="module">
  // Cart Management Logic
  class CartManager {
    constructor() {
      console.log('Contenido del carrito al inicializar:', localStorage.getItem('cart'));
      this.cart = JSON.parse(localStorage.getItem('cart') || '[]');
      this.updateUI();
      this.setupEventListeners();
    }

    setupEventListeners() {
      const cartButton = document.getElementById('cartOpenBtn');
      const closeCart = document.getElementById('closeCart');
      const cartOverlay = document.getElementById('cartOverlay');
      const checkoutBtn = document.getElementById('checkoutBtn');

      if (cartButton) cartButton.onclick = () => this.toggleCart();
      if (closeCart) closeCart.onclick = () => this.closeCart();
      if (cartOverlay) cartOverlay.onclick = () => this.closeCart();
      if (checkoutBtn) checkoutBtn.onclick = () => this.checkout();

      // Add to cart buttons
      if (!window.cartListenerAdded) {
        document.addEventListener('click', (e) => {
          const btn = e.target.closest('.btn-agregar') || e.target.closest('.add-to-cart');
          if (btn) {
            this.addToCart(btn);
          }
        });
        window.cartListenerAdded = true;
      }
    }

    addToCart(button) {
      const productId = String(button.dataset.id);
      const productName = button.dataset.name || 'Producto';
      const productImage = button.dataset.image || 'https://images.unsplash.com/photo-1552902865-b72c031ac5ea?q=80&w=200&auto=format&fit=crop';
      const stock = parseInt(button.dataset.stock) || 0;
      const productPrice = parseFloat(button.dataset.price) || 0;

      const itemExistente = this.cart.find(i => String(i.id) === productId);
      const cantidadActual = itemExistente ? parseInt(itemExistente.quantity) : 0;

      if (cantidadActual >= stock && stock > 0) {
        alert(`Stock agotado. Solo hay ${stock} unidad/es disponible/s.`);
        return;
      }

      const item = {
        id: productId,
        name: productName,
        price: productPrice,
        stock: stock,
        image: productImage,
        quantity: 1
      };

      if (itemExistente) {
        itemExistente.quantity++;
      } else {
        this.cart.push(item);
      }

      this.save();
      this.updateUI();
      this.openCart();
    }

    removeFromCart(productId) {
      this.cart = this.cart.filter(p => p.id !== productId);
      this.save();
      this.updateUI();
    }

    updateQuantity(productId, quantity) {
      const item = this.cart.find(p => String(p.id) === String(productId));
      if (item) {
        const newQty = Math.max(1, Math.min(parseInt(quantity), item.stock));
        item.quantity = newQty;
        this.save();
        this.updateUI();
      }
    }

    parsePrice(priceStr) {
      return parseFloat(priceStr.replace(/[^\d.-]/g, '')) || 0;
    }

    updateUI() {
      const badge = document.getElementById('cartBadge');
      const itemsContainer = document.getElementById('cartItems');
      const total = document.getElementById('cartTotal');

      // Update badge consistently
      window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { cart: this.cart } }));

      if (badge) {
        badge.textContent = this.cart.reduce((sum, item) => sum + parseInt(item.quantity), 0);
      }

      if (itemsContainer) {
        itemsContainer.innerHTML = this.cart.length
          ? this.cart.map(item => `
              <div class="cart-item">
                <img src="${item.image || 'https://images.unsplash.com/photo-1552902865-b72c031ac5ea?w=200'}" alt="${item.name}" class="cart-item-img" />
                <div class="item-info">
                  <h4>${item.name}</h4>
                  <p class="item-price">$ ${item.price.toLocaleString('es-AR')}</p>
                </div>
                <div class="item-controls">
                  <input type="number" value="${item.quantity}" min="1" max="${item.stock || 10}" data-id="${item.id}" class="qty-input">
                  <button class="remove-btn" data-id="${item.id}">Retirar</button>
                </div>
              </div>
            `).join('')
          : '<p class="empty-cart">Tu carrito está vacío</p>';

        // Add event listeners to quantity inputs and remove buttons
        itemsContainer.querySelectorAll('.qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            this.updateQuantity(e.target.dataset.id, parseInt(e.target.value));
          });
        });

        itemsContainer.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.removeFromCart(e.target.dataset.id);
          });
        });
      }

      if (total) {
        const totalAmount = this.cart.reduce((sum, item) => sum + (parseFloat(item.price) * parseInt(item.quantity)), 0);
        total.textContent = `$ ${totalAmount.toLocaleString('es-AR')}`;
      }
    }

    toggleCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.toggle('active');
    }

    openCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.add('active');
    }

    closeCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.remove('active');
    }

    checkout() {
      if (this.cart.length === 0) {
        alert('Tu carrito está vacío');
        return;
      }

      this.closeCart();

      const cartText = this.cart
        .map(item => `• ${item.name} (x${item.quantity}) - $ ${(parseFloat(item.price) * parseInt(item.quantity)).toLocaleString('es-AR')}`)
        .join('\n');

      const total = this.cart.reduce((sum, item) => sum + (parseFloat(item.price) * parseInt(item.quantity)), 0);
      const message = `🏴 *NUEVO PEDIDO - MELROSE* 🏴\n--------------------------------\nHola! Me gustaría realizar la compra de los siguientes artículos:\n\n${cartText}\n\n💰 *TOTAL:* $ ${total.toLocaleString('es-AR')}\n--------------------------------\n¿Cómo procedemos con el pago y el envío?`;

      window.open(`https://wa.me/5493624645328?text=${encodeURIComponent(message)}`, '_blank');
    }

    save() {
      localStorage.setItem('cart', JSON.stringify(this.cart));
    }
  }

  // Initialize cart safely with View Transitions support
  function initCart() {
    if (!window.cartManagerInstance) {
      window.cartManagerInstance = new CartManager();
    } else {
      window.cartManagerInstance.setupEventListeners();
      window.cartManagerInstance.updateUI();
    }
  }

  document.addEventListener('astro:page-load', initCart);
  
  if (document.readyState !== 'loading') {
    initCart();
  } else {
    document.addEventListener('DOMContentLoaded', initCart);
  }
</script>

<style>
  .cart-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(3px);
    z-index: 999;
  }

  .cart-overlay.active {
    display: block;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 380px;
    height: 100vh;
    background: var(--negro);
    border-left: 2px solid var(--cyan);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 999;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer.active {
    transform: translateX(0);
  }

  .cart-header {
    padding: 2rem;
    border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0, 212, 255, 0.02);
  }

  .cart-header h3 {
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--cyan);
    text-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
  }

  .close-cart {
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    font-size: 1.2rem;
    cursor: pointer;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
  }

  .close-cart:hover {
    background: var(--cyan);
    color: var(--negro);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
    transform: scale(1.1) rotate(90deg);
  }

  .cart-items {
    flex: 1;
    overflow-y: auto;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 70px 1fr auto;
    gap: 1rem;
    padding: 1rem;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    animation: slideIn 0.3s ease-out;
    align-items: center;
  }

  .cart-item-img {
    width: 70px;
    height: 70px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
    justify-content: center;
  }

  .item-info h4 {
    font-size: 0.7rem;
    line-height: 1.2;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--blanco);
    font-weight: 500;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .item-price {
    font-size: 0.95rem;
    color: var(--rojo);
    font-weight: 600;
    margin: 0;
  }

  .item-controls {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .qty-input {
    width: 45px;
    height: 35px;
    padding: 0 0.2rem;
    background: rgba(0, 212, 255, 0.05);
    border: 1px solid var(--cyan);
    color: var(--blanco);
    text-align: center;
    font-weight: 600;
    transition: all 0.3s ease;
    border-radius: 3px;
  }

  .qty-input:focus {
    outline: none;
    background: rgba(0, 212, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
  }

  /* Minimalist remove button */
  .remove-btn {
    background: transparent;
    border: none;
    color: var(--gris);
    padding: 0;
    margin-top: 0;
    font-size: 0.7rem;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
    text-decoration: underline;
    box-shadow: none;
  }

  .remove-btn:hover {
    background: transparent;
    color: var(--rojo);
    box-shadow: none;
    transform: none;
  }

  .empty-cart {
    text-align: center;
    opacity: 0.6;
    font-size: 0.9rem;
    color: var(--gris);
  }

  .cart-footer {
    padding: 2rem 0 0 0;
    border-top: 2px solid rgba(0, 212, 255, 0.2);
    background: rgba(0, 212, 255, 0.02);
    display: flex;
    flex-direction: column;
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 0 2rem;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cart-total span {
    color: var(--gris);
    font-weight: 600;
  }

  .cart-total strong {
    color: var(--blanco);
    font-size: 2rem;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.05em;
    text-shadow: none;
    line-height: 1;
  }

  /* Neon red hover "iguales a la Home" */
  .checkout-btn {
    width: 100%;
    display: block;
    text-align: center;
    background: var(--rojo);
    color: var(--blanco);
    border: none;
    padding: 15px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .checkout-btn:hover {
    background: #a02e22;
    box-shadow: 0 0 20px rgba(192, 57, 43, 0.6);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .cart-wrapper {
      bottom: 1rem;
      right: 1rem;
    }

    .cart-drawer {
      max-width: 100%;
    }

    @keyframes floatBag {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-5px);
      }
    }
  }
</style>
