---
// Carrito interactivo - necesita ser renderizado del lado del cliente
---

<aside class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <h3>TU CARRITO</h3>
    <button class="close-cart" id="closeCart">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer">
    <div class="cart-total">
      <span>TOTAL</span>
      <strong id="cartTotal">$ 0</strong>
    </div>
    <button class="btn-primary checkout-btn" id="checkoutBtn">FINALIZAR COMPRA</button>
  </div>
</aside>

<div class="cart-overlay" id="cartOverlay"></div>

<script type="module">
  // Cart Management Logic
  class CartManager {
    constructor() {
      console.log('Contenido del carrito al inicializar:', localStorage.getItem('cart'));
      this.cart = JSON.parse(localStorage.getItem('cart') || '[]');
      this.updateUI();
      this.setupEventListeners();
    }

    setupEventListeners() {
      const cartButton = document.getElementById('cartOpenBtn');
      const closeCart = document.getElementById('closeCart');
      const cartOverlay = document.getElementById('cartOverlay');
      const checkoutBtn = document.getElementById('checkoutBtn');

      if (cartButton) cartButton.onclick = () => this.toggleCart();
      if (closeCart) closeCart.onclick = () => this.closeCart();
      if (cartOverlay) cartOverlay.onclick = () => this.closeCart();
      if (checkoutBtn) checkoutBtn.onclick = () => this.checkout();

      // Add to cart buttons
      if (!window.cartListenerAdded) {
        document.addEventListener('click', (e) => {
          const btn = e.target.closest('.btn-agregar') || e.target.closest('.add-to-cart');
          if (btn) {
            this.addToCart(btn);
          }
        });
        window.cartListenerAdded = true;
      }
    }

    addToCart(button) {
      const productId = String(button.dataset.id);
      const productName = button.dataset.name || 'Producto';
      const productImage = button.dataset.image || 'https://images.unsplash.com/photo-1552902865-b72c031ac5ea?q=80&w=200&auto=format&fit=crop';
      const stock = parseInt(button.dataset.stock) || 0;
      const productPrice = parseFloat(button.dataset.price) || 0;

      const itemExistente = this.cart.find(i => String(i.id) === productId);
      const cantidadActual = itemExistente ? parseInt(itemExistente.quantity) : 0;

      if (cantidadActual >= stock) {
        this.showToast(`Stock agotado. Solo hay ${stock} unidad/es disponible/s.`);
        return;
      }

      const item = {
        id: productId,
        name: productName,
        price: productPrice,
        stock: stock,
        image: productImage,
        quantity: 1
      };

      if (itemExistente) {
        itemExistente.quantity++;
      } else {
        this.cart.push(item);
      }

      this.save();
      this.updateUI();
      this.openCart();
    }

    removeFromCart(productId) {
      this.cart = this.cart.filter(p => String(p.id) !== String(productId));
      this.save();
      this.updateUI();
    }

    updateQuantity(productId, quantity) {
      const item = this.cart.find(p => String(p.id) === String(productId));
      if (item) {
        const newQty = Math.max(1, Math.min(parseInt(quantity), item.stock));
        item.quantity = newQty;
        this.save();
        this.updateUI();
      }
    }

    parsePrice(priceStr) {
      return parseFloat(priceStr.replace(/[^\d.-]/g, '')) || 0;
    }

    updateUI() {
      const badge = document.getElementById('cartBadge');
      const itemsContainer = document.getElementById('cartItems');
      const total = document.getElementById('cartTotal');

      // Update badge consistently
      window.dispatchEvent(new CustomEvent('cartUpdated', { detail: { cart: this.cart } }));

      if (badge) {
        badge.textContent = this.cart.reduce((sum, item) => sum + parseInt(item.quantity), 0);
      }

      if (itemsContainer) {
        itemsContainer.innerHTML = this.cart.length
          ? this.cart.map(item => `
              <div class="cart-item">
                <img src="${item.image || 'https://images.unsplash.com/photo-1552902865-b72c031ac5ea?w=200'}" alt="${item.name}" class="cart-item-img" />
                <div class="cart-item-details">
                  <h4>${item.name}</h4>
                  <p class="item-price">$ ${item.price.toLocaleString('es-AR')}</p>
                </div>
                <div class="item-controls">
                  <input type="number" value="${item.quantity}" min="1" max="${item.stock || 10}" data-id="${item.id}" class="qty-input">
                  <button class="remove-btn" data-id="${item.id}">Retirar</button>
                </div>
              </div>
            `).join('')
          : '<p class="empty-cart">Tu carrito está vacío</p>';

        // Add event listeners to quantity inputs and remove buttons
        itemsContainer.querySelectorAll('.qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            this.updateQuantity(e.target.dataset.id, parseInt(e.target.value));
          });
        });

        itemsContainer.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.removeFromCart(e.target.dataset.id);
          });
        });
      }

      if (total) {
        const totalAmount = this.cart.reduce((sum, item) => sum + (parseFloat(item.price) * parseInt(item.quantity)), 0);
        total.textContent = `$ ${totalAmount.toLocaleString('es-AR')}`;
      }
    }

    toggleCart() {
      const drawer = document.getElementById('cartDrawer');
      const isActive = drawer?.classList.toggle('active');
      document.body.style.overflow = isActive ? 'hidden' : '';
    }

    openCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    closeCart() {
      const drawer = document.getElementById('cartDrawer');
      drawer?.classList.remove('active');
      document.body.style.overflow = '';
    }

    checkout() {
      if (this.cart.length === 0) {
        alert('Tu carrito está vacío');
        return;
      }

      this.closeCart();

      const cartText = this.cart
        .map(item => `• ${item.name} (x${item.quantity}) - $ ${(parseFloat(item.price) * parseInt(item.quantity)).toLocaleString('es-AR')}`)
        .join('\n');

      const total = this.cart.reduce((sum, item) => sum + (parseFloat(item.price) * parseInt(item.quantity)), 0);
      const message = `🏴 *NUEVO PEDIDO - MELROSE* 🏴\n--------------------------------\nHola! Me gustaría realizar la compra de los siguientes artículos:\n\n${cartText}\n\n💰 *TOTAL:* $ ${total.toLocaleString('es-AR')}\n--------------------------------\n¿Cómo procedemos con el pago y el envío?`;

      window.open(`https://wa.me/5493624645328?text=${encodeURIComponent(message)}`, '_blank');
    }

    save() {
      localStorage.setItem('cart', JSON.stringify(this.cart));
    }

    showToast(message) {
      const existing = document.querySelector('.melrose-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.className = 'melrose-toast';
      toast.innerHTML = `<span class="toast-icon">⚠️</span> ${message}`;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.classList.add('fade-out');
        setTimeout(() => toast.remove(), 400);
      }, 3000);
    }
  }

  // Initialize cart safely with View Transitions support
  function initCart() {
    if (!window.cartManagerInstance) {
      window.cartManagerInstance = new CartManager();
    } else {
      window.cartManagerInstance.setupEventListeners();
      window.cartManagerInstance.updateUI();
    }
  }

  document.addEventListener('astro:page-load', initCart);
  
  if (document.readyState !== 'loading') {
    initCart();
  } else {
    document.addEventListener('DOMContentLoaded', initCart);
  }
</script>

<style>
.cart-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(420px, 100vw);
  height: 100dvh;
  background: #0d0d0d;
  border-left: 1px solid rgba(255,255,255,0.08);
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 999;
  display: flex;
  flex-direction: column;
}
.cart-drawer.active { transform: translateX(0); }
.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 1.75rem;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.cart-header h3 { font-size: 0.85rem; letter-spacing: 0.15em; color: #fff; margin: 0; }
.close-cart { background: none; border: none; color: #888; font-size: 1.1rem; cursor: pointer; transition: color 0.2s; padding: 0.25rem; line-height: 1; }
.close-cart:hover { color: #fff; }
.cart-items { flex: 1; overflow-y: auto; padding: 1.25rem 1.75rem; display: flex; flex-direction: column; gap: 1rem; }
.cart-items::-webkit-scrollbar { width: 4px; }
.cart-items::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
.cart-item { display: grid; grid-template-columns: 72px 1fr auto; gap: 1rem; align-items: center; background: #161616; border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 0.75rem; }
.cart-item-img { width: 72px; height: 72px; object-fit: cover; border-radius: 5px; display: block; }
.cart-item-details { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; }
.cart-item-details h4 { font-size: 0.8rem; font-weight: 600; color: #fff; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-price { font-size: 0.85rem; color: #e05a2b; font-weight: 700; margin: 0; }
.item-controls { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; }
.qty-input { width: 48px; background: #222; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; color: #fff; font-size: 0.8rem; text-align: center; padding: 0.25rem; }
.remove-btn { background: none; border: none; color: #555; font-size: 0.7rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; transition: color 0.2s; padding: 0; white-space: nowrap; }
.remove-btn:hover { color: #e05a2b; }
.empty-cart { color: #555; font-size: 0.85rem; text-align: center; margin-top: 3rem; letter-spacing: 0.05em; }
.cart-footer { padding: 1.25rem 1.75rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 1rem; }
.cart-total { display: flex; justify-content: space-between; align-items: center; }
.cart-total span { font-size: 0.75rem; letter-spacing: 0.12em; color: #888; }
.cart-total strong { font-size: 1.25rem; color: #fff; font-weight: 700; }
.checkout-btn { width: 100%; padding: 1rem; background: #e05a2b; color: #fff; border: none; border-radius: 6px; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; cursor: pointer; transition: background 0.2s; text-transform: uppercase; }
.checkout-btn:hover { background: #c94e24; }
.cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(2px); z-index: 998; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
.cart-drawer.active ~ .cart-overlay { opacity: 1; pointer-events: all; }
</style>
