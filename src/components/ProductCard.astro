---
interface Props {
  product: {
    id: string;
    nombre: string;
    precio: number;
    imagen_url: string;
    categoria: string;
    descripcion?: string;
    stock: number;
  }
}

const { product } = Astro.props;
const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});
---

<article class="product-card">
  <div class="product-image-wrap">
    <img src={product.imagen_url} alt={product.nombre} loading="lazy" class="product-img" />
    <button 
      class="wishlist-btn"
      data-id={product.id}
      data-name={product.nombre}
      data-price={product.precio}
      data-image={product.imagen_url}
      data-category={product.categoria}
      aria-label="Agregar a favoritos"
    >
      <svg class="heart-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="product-info">
    <div class="product-header">
      <h3 class="product-name">{product.nombre}</h3>
      <p class="product-category">{product.categoria}</p>
    </div>
    <p class="product-price">{formatter.format(product.precio)}</p>
    <button class="btn-agregar" data-id={product.id} data-price={product.precio} data-name={product.nombre} data-stock={product.stock}>AGREGAR</button>
  </div>
</article>

<style>
  .product-card {
    background: var(--negro);
    border: 1px solid var(--borde);
    transition: all 0.3s ease;
    width: 100%;
    position: relative;
    overflow: hidden;
    opacity: 1;
  }

  .product-card:hover {
    border-color: var(--rojo);
    transform: scale(1.05);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }

  .product-image-wrap {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: var(--negro);
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .product-image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(192, 57, 43, 0.15); /* Soft red overlay */
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
    z-index: 1;
  }

  .wishlist-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--blanco);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
    backdrop-filter: blur(10px);
  }

  .wishlist-btn:hover {
    background: rgba(192, 57, 43, 0.9);
    transform: scale(1.1);
    border-color: var(--magenta);
    box-shadow: 0 0 20px rgba(255, 0, 255, 0.3);
  }

  .wishlist-btn.active {
    background: var(--magenta);
    color: var(--blanco);
    border-color: var(--magenta);
    box-shadow: 0 0 25px rgba(255, 0, 255, 0.6), inset 0 0 10px rgba(255, 255, 255, 0.2);
    animation: neonPulse 2s ease-in-out infinite;
  }

  .wishlist-btn.active:hover {
    background: var(--magenta);
    transform: scale(1.15);
    box-shadow: 0 0 30px rgba(255, 0, 255, 0.8), inset 0 0 15px rgba(255, 255, 255, 0.3);
  }

  @keyframes neonPulse {
    0%, 100% {
      box-shadow: 0 0 25px rgba(255, 0, 255, 0.6), inset 0 0 10px rgba(255, 255, 255, 0.2);
    }
    50% {
      box-shadow: 0 0 35px rgba(255, 0, 255, 0.9), inset 0 0 15px rgba(255, 255, 255, 0.4);
    }
  }

  .heart-icon {
    width: 18px;
    height: 18px;
    transition: all 0.3s ease;
  }

  .wishlist-btn.active svg {
    fill: var(--magenta);
    stroke: var(--magenta);
    filter: drop-shadow(0 0 8px rgba(255, 0, 255, 0.8));
  }

  .wishlist-btn:not(.active) svg {
    fill: none;
    stroke: currentColor;
  }

  .product-card:hover .product-img {
    transform: scale(1.15);
  }

  .product-card:hover .product-image-wrap::after {
    opacity: 1;
  }

  .product-info {
    padding: 1rem;
    display: grid;
    gap: 0.6rem;
    background: var(--negro);
  }

  .product-header {
    display: grid;
    gap: 0.3rem;
  }

  .product-name {
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--blanco);
    line-height: 1.2;
  }

  .product-category {
    font-size: 0.7rem;
    color: var(--rojo);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .product-price {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--blanco);
  }

  .add-to-cart {
    background: transparent;
    border: 1px solid var(--rojo);
    color: var(--blanco);
    padding: 0.7rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .add-to-cart::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--rojo);
    transition: left 0.3s ease;
    z-index: -1;
  }

  .add-to-cart:hover {
    color: var(--negro);
    border-color: var(--rojo);
  }

  .add-to-cart:hover::before {
    left: 0;
  }

  .add-to-cart:active {
    transform: scale(0.98);
  }

  .btn-agregar {
    background: var(--rojo);
    color: var(--blanco);
    border: none;
    padding: 10px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    width: 100%;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-agregar:hover {
    background: #a02e22;
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
    transform: translateY(-2px) scale(1.02);
  }

  .btn-agregar::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.3), transparent);
    transition: left 0.6s ease;
  }

  .btn-agregar:hover::before {
    left: 100%;
  }

  .btn-agregar:active {
    transform: translateY(0) scale(0.98);
    box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
  }

  /* Tablet responsive */
  @media (max-width: 1024px) {
    .product-image-wrap {
      height: 240px;
    }

    .wishlist-btn {
      width: 36px;
      height: 36px;
      top: 0.75rem;
      right: 0.75rem;
    }

    .heart-icon {
      width: 16px;
      height: 16px;
    }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .product-image-wrap {
      height: 200px;
    }

    .wishlist-btn {
      width: 32px;
      height: 32px;
      top: 0.5rem;
      right: 0.5rem;
    }

    .heart-icon {
      width: 14px;
      height: 14px;
    }

    .product-info {
      padding: 0.75rem;
    }

    .product-name {
      font-size: 1rem;
    }

    .product-price {
      font-size: 1rem;
    }

    .add-to-cart {
      padding: 0.6rem 0.8rem;
      font-size: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    .product-image-wrap {
      height: 180px;
    }

    .wishlist-btn {
      width: 28px;
      height: 28px;
      top: 0.4rem;
      right: 0.4rem;
    }

    .heart-icon {
      width: 12px;
      height: 12px;
    }

    .product-info {
      padding: 0.5rem;
    }

    .product-name {
      font-size: 0.9rem;
    }

    .product-price {
      font-size: 0.85rem;
    }

    .add-to-cart {
      padding: 0.5rem 0.6rem;
      font-size: 0.65rem;
    }
  }
</style>
