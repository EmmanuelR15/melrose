---
interface Props {
  product: {
    id: string;
    nombre: string;
    precio: number;
    imagen_url: string;
    categoria: string;
    descripcion?: string;
  }
}

const { product } = Astro.props;
const formatter = new Intl.NumberFormat('es-AR', {
  style: 'currency',
  currency: 'ARS',
  minimumFractionDigits: 0,
});
---

<article class="product-card">
  <div class="product-image-wrap">
    <img src={product.imagen_url} alt={product.nombre} loading="lazy" class="product-img" />
  </div>

  <div class="product-info">
    <div class="product-header">
      <h3 class="product-name">{product.nombre}</h3>
      <p class="product-category">{product.categoria}</p>
    </div>
    <p class="product-price">{formatter.format(product.precio)}</p>
    <button class="add-to-cart btn-agregar" data-id={product.id}>AGREGAR</button>
  </div>
</article>

<style>
  .product-card {
    background: var(--negro);
    border: 1px solid var(--borde);
    transition: all 0.3s ease;
    width: 100%;
    position: relative;
    overflow: hidden;
    opacity: 1;
  }

  .product-card:hover {
    border-color: var(--rojo);
    transform: scale(1.05);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }

  .product-image-wrap {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: var(--negro);
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-img {
    transform: scale(1.1);
  }

  .product-info {
    padding: 1rem;
    display: grid;
    gap: 0.6rem;
    background: var(--negro);
  }

  .product-header {
    display: grid;
    gap: 0.3rem;
  }

  .product-name {
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--blanco);
    line-height: 1.2;
  }

  .product-category {
    font-size: 0.7rem;
    color: var(--rojo);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .product-price {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--blanco);
  }

  .add-to-cart {
    background: transparent;
    border: 1px solid var(--rojo);
    color: var(--blanco);
    padding: 0.7rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .add-to-cart::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--rojo);
    transition: left 0.3s ease;
    z-index: -1;
  }

  .add-to-cart:hover {
    color: var(--negro);
    border-color: var(--rojo);
  }

  .add-to-cart:hover::before {
    left: 0;
  }

  .add-to-cart:active {
    transform: scale(0.98);
  }

  .btn-agregar {
    background: var(--rojo);
    color: var(--blanco);
    border: none;
    padding: 10px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s ease;
  }

  .btn-agregar:hover {
    background: var(--rojo-oscuro);
  }

  @media (max-width: 768px) {
    .product-info {
      padding: 1rem;
    }

    .product-name {
      font-size: 0.8rem;
    }

    .product-price {
      font-size: 1rem;
    }

    .add-to-cart {
      padding: 0.6rem 0.8rem;
      font-size: 0.7rem;
    }
  }
</style>
