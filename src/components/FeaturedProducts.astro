---
import ProductCard from './ProductCard.astro';
import { supabase } from '../lib/supabase';

// Fallback products with destacado field
const fallbackProducts = [
  {
    id: 'fallback-1',
    nombre: 'URBAN TEE CLASSIC',
    precio: 45000,
    imagen_url: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=600&h=800&fit=crop',
    categoria: 'REMERAS',
    descripcion: 'Remera clásica urbana con logo bordado',
    stock: 15,
    destacado: true
  },
  {
    id: 'fallback-2',
    nombre: 'STREET HOODIE PRO',
    precio: 78000,
    imagen_url: 'https://images.unsplash.com/photo-1556821840-3a8f3ea9f747?w=600&h=800&fit=crop',
    categoria: 'BUZOS',
    descripcion: 'Buzo premium con capucha y bolsillos frontales',
    stock: 8,
    destacado: true
  },
  {
    id: 'fallback-3',
    nombre: 'CARGO PANTS BLACK',
    precio: 95000,
    imagen_url: 'https://images.unsplash.com/photo-1541099649105-f69ad21f3242?w=600&h=800&fit=crop',
    categoria: 'PANTALONES',
    descripcion: 'Pantalones cargo con múltiples bolsillos',
    stock: 12,
    destacado: false
  },
  {
    id: 'fallback-4',
    nombre: 'URBAN CAP BLACK',
    precio: 35000,
    imagen_url: 'https://images.unsplash.com/photo-1576871337622-101f8921f9e1?w=600&h=800&fit=crop',
    categoria: 'ACCESORIOS',
    descripcion: 'Gorra urbana con logo bordado',
    stock: 20,
    destacado: false
  }
];

// Try to fetch featured products from Supabase
let featuredProducts = [];

try {
  if (supabase) {
    // First try: get products with destacado = true
    const { data: destacados, error } = await supabase
      .from('productos')
      .select('*')
      .eq('destacado', true)
      .limit(4);

    if (!error && destacados && destacados.length > 0) {
      featuredProducts = destacados;
      console.log('⭐ Destacados from Supabase:', destacados.length);
    } else {
      // Fallback: get first 4 products
      const { data: allProducts, error: allError } = await supabase
        .from('productos')
        .select('*')
        .order('created_at', { ascending: false })
        .limit(4);

      if (!allError && allProducts && allProducts.length > 0) {
        featuredProducts = allProducts;
        console.log('📦 Using first 4 products as featured fallback:', allProducts.length);
      } else {
        // Use local fallback
        featuredProducts = fallbackProducts.filter(p => p.destacado === true).slice(0, 4);
        if (featuredProducts.length === 0) {
          featuredProducts = fallbackProducts.slice(0, 4);
        }
        console.log('📦 Using hardcoded fallback products');
      }
    }
  } else {
    // No Supabase: use local fallback
    featuredProducts = fallbackProducts.filter(p => p.destacado === true).slice(0, 4);
    if (featuredProducts.length === 0) {
      featuredProducts = fallbackProducts.slice(0, 4);
    }
  }
} catch (err) {
  console.error('Error fetching featured products:', err);
  featuredProducts = fallbackProducts.filter(p => p.destacado === true).slice(0, 4);
  if (featuredProducts.length === 0) {
    featuredProducts = fallbackProducts.slice(0, 4);
  }
}
---

<section class="featured-products" id="destacados">
  <div class="container">
    <div class="section-header">
      <h2>DESTACADOS</h2>
      <p>Las piezas más representativas de la temporada</p>
    </div>

    {featuredProducts.length > 0 ? (
      <div class="products-grid">
        {featuredProducts.map((product) => (
          <div class="featured-card-wrap">
            <span class="featured-tag">DESTACADO</span>
            <ProductCard product={product} />
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-featured">
        <div class="glitch-text">NEW DROP COMING SOON</div>
      </div>
    )}
  </div>
</section>

<style>
  .featured-products {
    padding: 6rem 0;
    background: var(--negro);
    border-top: 1px solid var(--borde);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 100%;
  }

  .featured-card-wrap {
    position: relative;
  }

  .featured-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 10;
    background: #c0392b;
    color: #fff;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 4px 12px;
    font-weight: 700;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(192, 57, 43, 0.5);
    pointer-events: none;
  }

  .empty-featured {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 6rem 0;
    min-height: 300px;
  }

  .glitch-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    text-transform: uppercase;
    position: relative;
    animation: glitch 2s infinite;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: 'NEW DROP COMING SOON';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .glitch-text::before {
    animation: glitch-1 0.5s infinite;
    color: var(--cyan);
    z-index: -1;
  }

  .glitch-text::after {
    animation: glitch-2 0.5s infinite;
    color: var(--rojo);
    z-index: -2;
  }

  @keyframes glitch {
    0%, 100% {
      text-shadow: 
        0 0 5px rgba(192, 57, 43, 0.5),
        0 0 10px rgba(0, 255, 255, 0.3);
    }
    25% {
      text-shadow: 
        2px 0 5px rgba(192, 57, 43, 0.5),
        -2px 0 10px rgba(0, 255, 255, 0.3);
    }
    50% {
      text-shadow: 
        -2px 0 5px rgba(192, 57, 43, 0.5),
        2px 0 10px rgba(0, 255, 255, 0.3);
    }
    75% {
      text-shadow: 
        0 0 5px rgba(192, 57, 43, 0.5),
        0 0 10px rgba(0, 255, 255, 0.3);
    }
  }

  @keyframes glitch-1 {
    0%, 100% { clip-path: inset(0 0 0 0); }
    25% { clip-path: inset(20% 0 30% 0); }
    50% { clip-path: inset(50% 0 20% 0); }
    75% { clip-path: inset(10% 0 60% 0); }
  }

  @keyframes glitch-2 {
    0%, 100% { clip-path: inset(0 0 0 0); }
    25% { clip-path: inset(60% 0 10% 0); }
    50% { clip-path: inset(20% 0 50% 0); }
    75% { clip-path: inset(30% 0 20% 0); }
  }

  @media (max-width: 768px) {
    .featured-products {
      padding: 4rem 0;
    }

    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }
</style>