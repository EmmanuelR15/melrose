---
import { Image } from 'astro:assets';
const heroImage = "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2000&auto=format&fit=crop";
---

<header class="hero">
  <div class="hero-bg">
    <img 
      src={heroImage} 
      alt="Melrose Hero" 
      class="hero-img"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="hero-kicker" id="heroKicker">MELROSE / EST. 2026</p>
    <h1>
      <span class="line">NUEVA</span>
      <span class="line">TEMPORADA</span>
      <span class="line year">2026</span>
    </h1>
    <p class="hero-description">Siluetas limpias, color profundo y textura premium. Una colección pensada para moverse entre ciudad, noche y diario.</p>
    <a href="#productos" class="btn-primary" id="heroCtaBtn">EXPLORAR</a>
  </div>
</header>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    color: var(--blanco);
    background: radial-gradient(ellipse at center, #1a0000 0%, #0a0a0a 70%);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, #3d0000 0%, transparent 70%);
    animation: breathe 5s ease-in-out infinite;
    z-index: 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-img {
    width: 100%;
    height: 120%;
    position: absolute;
    top: -10%;
    left: 0;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.8));
  }

  .hero-content {
    max-width: 100%;
    padding: 0 1.5rem;
    z-index: 1;
  }

  .hero-kicker {
    letter-spacing: 0.7em;
    font-size: 0.8rem;
    margin-bottom: 2rem;
    opacity: 0.9;
    text-transform: uppercase;
    animation: fadeInUp 0.8s ease-out;
    color: var(--rojo);
  }

  h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    gap: 0.1em;
    margin-bottom: 2rem;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .line {
    font-size: clamp(4.5rem, 18vw, 8rem);
    letter-spacing: 0.05em;
    font-weight: 900;
  }

  .year {
    font-size: clamp(3rem, 14vw, 6rem);
    color: var(--rojo);
    letter-spacing: 0.2em;
    font-weight: 900;
  }

  .hero-description {
    max-width: 500px;
    margin: 0 auto;
    font-size: 1rem;
    opacity: 0.85;
    animation: fadeInUp 0.8s ease-out 0.4s both;
    line-height: 1.6;
  }

  .btn-primary {
    margin-top: 1.5rem;
    animation: fadeInUp 0.8s ease-out 0.6s both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes breathe {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.15); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 80px 1.5rem 20px;
      gap: 0.5rem;
    }

    .hero-content {
      padding: 0 1rem;
    }

    .hero-description {
      font-size: 0.9rem;
    }
  }
</style>
