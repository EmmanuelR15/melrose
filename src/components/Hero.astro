---
import { Image } from 'astro:assets';
const heroImage = "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2000&auto=format&fit=crop";
---

<header class="hero">
  <div class="hero-bg">
    <img 
      src={heroImage} 
      alt="STW Hero" 
      class="hero-img"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="hero-kicker" id="heroKicker">STW / DROP 01</p>
    <h1 id="heroTitle">NUEVA<br>TEMPORADA<br>2026</h1>
    <p class="hero-description">Siluetas limpias, color profundo y textura premium. Una colección pensada para moverse entre ciudad, noche y diario.</p>
    <a href="#productos" class="btn-primary" id="heroCtaBtn">EXPLORAR</a>
  </div>
</header>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    color: var(--blanco);
    background: var(--negro);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.8));
  }

  .hero-content {
    max-width: 900px;
    padding: 0 1.5rem;
    z-index: 1;
  }

  .hero-kicker {
    letter-spacing: 0.7em;
    font-size: 0.8rem;
    margin-bottom: 2rem;
    opacity: 0.9;
    text-transform: uppercase;
    animation: fadeInUp 0.8s ease-out;
    color: var(--rojo);
  }

  h1 {
    font-size: clamp(3rem, 10vw, 9rem);
    line-height: 0.85;
    margin-bottom: 2rem;
    letter-spacing: 0.08em;
    font-weight: 900;
    animation: fadeInUp 0.8s ease-out 0.2s both;
    white-space: normal;
  }

  .hero-description {
    max-width: 500px;
    margin: 0 auto;
    font-size: 1rem;
    opacity: 0.85;
    animation: fadeInUp 0.8s ease-out 0.4s both;
    line-height: 1.6;
  }

  .btn-primary {
    margin-top: 3rem;
    animation: fadeInUp 0.8s ease-out 0.6s both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 0 1rem;
    }
    
    h1 {
      font-size: clamp(3rem, 15vw, 8rem);
    }
    
    .hero-description {
      font-size: 0.9rem;
    }
  }
</style>
    }
  }
</style>
