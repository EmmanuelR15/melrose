---
import { Image } from 'astro:assets';
const heroImage = "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2000&auto=format&fit=crop";
---

<header class="hero">
  <div class="hero-bg">
    <img 
      src={heroImage} 
      alt="STW Hero" 
      class="hero-img"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="hero-kicker" id="heroKicker">STW / DROP 01</p>
    <h1 id="heroTitle">NUEVA<br>TEMPORADA<br>2026</h1>
    <p class="hero-description">Siluetas limpias, color profundo y textura premium. Una colección pensada para moverse entre ciudad, noche y diario.</p>
    <a href="#productos" class="btn-primary" id="heroCtaBtn">EXPLORAR</a>
  </div>
</header>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    color: var(--blanco);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.7));
  }

  .hero-content {
    max-width: 900px;
    padding: 0 1.5rem;
    z-index: 1;
  }

  .hero-kicker {
    letter-spacing: 0.7em;
    font-size: 0.8rem;
    margin-bottom: 2rem;
    opacity: 1;
  }

  h1 {
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.85;
    margin-bottom: 2rem;
    letter-spacing: 0.08em;
  }

  .hero-description {
    max-width: 500px;
    margin: 0 auto;
    font-size: 1rem;
    opacity: 0.8;
  }

  .btn-primary {
    margin-top: 3rem;
  }
</style>
