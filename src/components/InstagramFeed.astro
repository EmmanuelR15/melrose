---
// Instagram Feed Component - API Integration with Fallback
import { createInstagramAPI, instagramFallbackData } from '../lib/instagram-api.js';

// Intentar obtener posts de Instagram API
const instagramAPI = createInstagramAPI();
let instagramPosts = [];

if (instagramAPI) {
  instagramPosts = await instagramAPI.getRecentPosts(6);
}

// Usar fallback si no hay posts de la API
const displayPosts = instagramPosts.length > 0 ? instagramPosts : instagramFallbackData;
---

<section class="instagram-feed">
  <div class="container">
    <div class="section-header">
      <h2>TENDENCIAS</h2>
      <p>Lo más reciente en nuestro Instagram</p>
    </div>

    <!-- Instagram Embeds sin embed.js (evita unload violation) -->
    <div class="instagram-embed">
      <div class="instagram-posts-grid">
        <!-- Post 1: Nueva Temporada 2026 -->
        <div class="instagram-post-static">
          <a 
            href="https://www.instagram.com/p/CzX9Y2KJ8Q/" 
            target="_blank"
            rel="noopener noreferrer"
            class="instagram-link"
          >
            <div class="instagram-preview">
              <div class="instagram-thumbnail">
                <img 
                  src="https://instagram.com/p/CzX9Y2KJ8Q/media" 
                  alt="Nueva Temporada 2026 - MELROSE"
                  loading="lazy"
                  onerror="this.src='/placeholder-instagram.jpg'"
                />
              </div>
              <div class="instagram-content">
                <div class="instagram-header">
                  <span class="instagram-account">@melrose</span>
                  <span class="instagram-date">hace 2 días</span>
                </div>
                <p class="instagram-caption">Nueva Temporada 2026 ya disponible en MELROSE Streetwear</p>
                <div class="instagram-footer">
                  <span class="instagram-likes">2.8k likes</span>
                  <span class="instagram-comments">89 comments</span>
                </div>
              </div>
            </div>
          </a>
        </div>
        
        <!-- Post 2: Streetwear Essentials -->
        <div class="instagram-post-static">
          <a 
            href="https://www.instagram.com/p/CyX7W2KJ8Q/" 
            target="_blank"
            rel="noopener noreferrer"
            class="instagram-link"
          >
            <div class="instagram-preview">
              <div class="instagram-thumbnail">
                <img 
                  src="https://instagram.com/p/CyX7W2KJ8Q/media" 
                  alt="Streetwear Essentials - MELROSE"
                  loading="lazy"
                  onerror="this.src='/placeholder-instagram.jpg'"
                />
              </div>
              <div class="instagram-content">
                <div class="instagram-header">
                  <span class="instagram-account">@melrose</span>
                  <span class="instagram-date">hace 5 días</span>
                </div>
                <p class="instagram-caption">Streetwear Essentials: las piezas que no pueden faltar en tu guardarropa</p>
                <div class="instagram-footer">
                  <span class="instagram-likes">1.5k likes</span>
                  <span class="instagram-comments">45 comments</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    
    <!-- Validation Script sin unload -->
    <script>
      // Validar embeds estáticos de Instagram (sin unload violation)
      document.addEventListener('DOMContentLoaded', function() {
        const instagramPosts = document.querySelectorAll('.instagram-post-static');
        
        // Usar pagehide en lugar de unload para cleanup seguro
        window.addEventListener('pagehide', (e) => {
          // Cleanup seguro cuando la página se oculta
          console.log('Instagram feed cleanup on pagehide');
        }, { capture: true });
        
        // Usar visibilitychange para detectar cuando la página no está visible
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') {
            // Cleanup cuando la página no está visible
            console.log('Instagram feed cleanup on visibility change');
          }
        });
        
        // Validar carga de imágenes
        instagramPosts.forEach((post, index) => {
          const img = post.querySelector('img');
          img.addEventListener('load', () => {
            console.log(`Instagram post ${index + 1} loaded successfully`);
          });
          img.addEventListener('error', () => {
            console.warn(`Instagram post ${index + 1} image failed to load, using fallback`);
          });
        });
        
        console.log('Instagram static embeds initialized without unload violations');
      });
    </script>
    </div>

    <!-- Grid de posts (dinámico desde API o fallback) -->
    <div class="instagram-grid">
      {displayPosts.map((post) => (
        <div class="instagram-item">
          <img 
            src={post.mediaUrl} 
            alt={post.caption || 'Instagram post'} 
            loading="lazy"
          />
          <div class="instagram-overlay">
            <span class="caption">{post.caption}</span>
            <a href={post.permalink} target="_blank" class="view-more">VER EN INSTAGRAM</a>
          </div>
        </div>
      ))}
    </div>

    <div class="instagram-footer">
      <a href="https://www.instagram.com/melrose/?hl=es-la" target="_blank" class="btn-secondary">
        SEGUIR EN INSTAGRAM
      </a>
    </div>
  </div>
</section>

<style>
  .instagram-feed {
    padding: 6rem 0;
    background: var(--negro);
    border-top: 1px solid var(--borde);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--blanco);
    margin-bottom: 1rem;
    font-family: 'Bebas Neue', sans-serif;
  }

  .section-header p {
    font-size: 1rem;
    color: var(--gris);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .instagram-embed {
    margin-bottom: 3rem;
    display: flex;
    justify-content: center;
  }

  .instagram-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Static Instagram Embeds Styles */
  .instagram-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .instagram-post-static {
    background: #FFF;
    border: 0;
    border-radius: 8px;
    box-shadow: 0 0 1px 0 rgba(0,0,0,0.5), 0 1px 10px 0 rgba(0,0,0,0.15);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .instagram-post-static:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  .instagram-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .instagram-preview {
    display: flex;
    flex-direction: column;
  }

  .instagram-thumbnail {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .instagram-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .instagram-post-static:hover .instagram-thumbnail img {
    transform: scale(1.05);
  }

  .instagram-content {
    padding: 1rem;
  }

  .instagram-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .instagram-account {
    font-weight: 600;
    color: #000;
    font-size: 0.9rem;
  }

  .instagram-date {
    color: #666;
    font-size: 0.8rem;
  }

  .instagram-caption {
    color: #000;
    font-size: 0.9rem;
    line-height: 1.4;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .instagram-footer {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: #666;
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .instagram-item {
    position: relative;
    aspect-ratio: 1;
    background: var(--negro-suave);
    border: 1px solid var(--borde);
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .instagram-item:hover {
    transform: scale(1.02);
    border-color: var(--rojo);
  }

  .instagram-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(192, 57, 43, 0.9), rgba(0, 0, 0, 0.8));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .instagram-item:hover .instagram-overlay {
    opacity: 1;
  }

  .caption {
    color: var(--blanco);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    text-align: center;
  }

  .view-more {
    color: var(--blanco);
    font-size: 0.8rem;
    text-decoration: none;
    border: 1px solid var(--blanco);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .view-more:hover {
    background: var(--blanco);
    color: var(--negro);
  }

  .instagram-footer {
    text-align: center;
  }

  @media (max-width: 1200px) {
    .instagram-posts-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 1024px) {
    .instagram-posts-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .section-header h2 {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .instagram-posts-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .instagram-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .container {
      padding: 0 1rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-size: 2rem;
    }

    .instagram-item {
      min-height: 200px;
    }

    .caption {
      font-size: 0.8rem;
    }

    .view-more {
      font-size: 0.7rem;
      padding: 0.4rem 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .instagram-feed {
      padding: 4rem 0;
    }

    .section-header {
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.8rem;
    }

    .section-header p {
      font-size: 0.9rem;
    }

    .instagram-grid {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .instagram-item {
      min-height: 180px;
    }

    .caption {
      font-size: 0.75rem;
    }

    .view-more {
      font-size: 0.65rem;
      padding: 0.3rem 0.6rem;
    }

    .instagram-posts-grid {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .instagram-embed {
      margin-bottom: 2rem;
    }
  }

  @media (max-width: 360px) {
    .instagram-feed {
      padding: 3rem 0;
    }

    .section-header h2 {
      font-size: 1.6rem;
    }

    .instagram-item {
      min-height: 160px;
    }

    .caption {
      font-size: 0.7rem;
    }

    .view-more {
      font-size: 0.6rem;
      padding: 0.25rem 0.5rem;
    }
  }
</style>
