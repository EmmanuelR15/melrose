---
// Footer with large brand name, functional links, and copyright
---

<footer class="footer" id="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <span class="footer-logo">MELROSE</span>
      <p class="footer-tagline">PREMIUM STREETWEAR — EST. 2026</p>
    </div>

    <div class="footer-nav">
      <h4 class="footer-heading">NAVEGACIÓN</h4>
      <div class="footer-links">
        <a href="/">HOME</a>
        <a href="#productos">SHOP</a>
        <a href="#ubicacion">CONTACTO</a>
        <a href="/favoritos">FAVORITOS</a>
      </div>
    </div>

    <div class="footer-info">
      <h4 class="footer-heading">INFO</h4>
      <div class="footer-links">
        <span>La Leonesa, Chaco, Argentina</span>
        <span>Envíos a todo el país</span>
      </div>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">CONTACTO</h4>
      <div class="footer-links">
        <a href="https://www.instagram.com/melrose.stw/?hl=es-la" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          INSTAGRAM
        </a>
        <a href="https://wa.me/5493624645328" target="_blank" rel="noopener noreferrer" class="footer-social-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.06 3.978L0 16l4.104-1.076a7.864 7.864 0 0 0 3.89 1.013h.005c4.368 0 7.926-3.558 7.93-7.93a7.897 7.897 0 0 0-2.328-5.681zM7.994 14.52a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
          </svg>
          WHATSAPP
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-line"></div>
    <p class="footer-copyright">© 2026 MELROSE. TODOS LOS DERECHOS RESERVADOS.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--negro-suave);
    border-top: 1px solid var(--borde);
    padding: 5rem 5% 2rem;
    margin-top: 0;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    color: #ffffff;
    letter-spacing: 0.15em;
    line-height: 1;
    text-shadow:
      0 0 5px rgba(192, 57, 43, 0.6),
      0 0 10px rgba(192, 57, 43, 0.4),
      0 0 20px rgba(192, 57, 43, 0.2);
  }

  .footer-tagline {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--gris);
    text-transform: uppercase;
    opacity: 0.7;
  }

  .footer-heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--blanco);
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .footer-nav .footer-links,
  .footer-info .footer-links,
  .footer-contact .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a,
  .footer-links span {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gris);
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--rojo);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
  }

  .footer-social-link svg {
    transition: transform 0.3s ease, fill 0.3s ease, stroke 0.3s ease;
  }

  .footer-social-link:hover {
    color: var(--rojo) !important;
  }

  .footer-social-link:hover svg {
    fill: var(--rojo);
    stroke: var(--rojo);
    transform: translateY(-2px);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 3rem auto 0;
  }

  .footer-line {
    width: 100%;
    height: 1px;
    background: var(--borde);
    margin-bottom: 1.5rem;
  }

  .footer-copyright {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gris);
    opacity: 0.5;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 4rem 5% 2rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-logo {
      font-size: 2.8rem;
    }

    .footer-nav .footer-links,
    .footer-info .footer-links,
    .footer-contact .footer-links {
      align-items: center;
    }

    .footer-bottom {
      margin-top: 2rem;
    }
  }
</style>
