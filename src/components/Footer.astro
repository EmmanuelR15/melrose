---
import logo from '../assets/logomelrose.jpg';
---

<footer class="footer" id="footer">
  <div class="footer-container">
    <div class="footer-logo">
      <img src={logo} alt="MELROSE | STW" class="logo-img" />
      <span class="brand-text">MELROSE | STW</span>
    </div>

    <div class="footer-links">
      <a href="#productos">SHOP</a>
      <a href="https://www.instagram.com/melrose.stw/" target="_blank" rel="noopener noreferrer">INSTAGRAM</a>
    </div>

    <div class="footer-copyright">
      <p>© 2026 MELROSE. ALL RIGHTS RESERVED.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--negro-suave);
    border-top: 1px solid var(--borde);
    padding: 6rem 5% 3rem;
    margin-top: 15rem;
  }

  .footer-container {
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .logo-img {
    height: 50px;
    width: auto;
    object-fit: contain;
  }

  .brand-text {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--rojo);
  }

  .footer-copyright {
    grid-column: 1 / -1;
    padding-top: 3rem;
    border-top: 1px solid var(--borde);
  }

  .footer-copyright p {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 4rem 3% 2rem;
      margin-top: 10rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      gap: 1rem;
    }

    .logo-img {
      height: 40px;
    }
  }
</style>
