---
// Clean footer with logo, links, and copyright
---

<footer class="footer" id="footer">
  <div class="footer-container">
    <div class="footer-logo">
      <img src="/assets/Gemini_Generated_Image_ij5pthij5pthij5p.png" alt="MELROSE | STW" class="logo-img" />
    </div>

    <div class="footer-links">
      <a href="#productos">SHOP</a>
      <a href="#lookbook">LOOKBOOK</a>
      <a href="#nosotros">NOSOTROS</a>
    </div>

    <div class="footer-copyright">
      <p>© 2026 MELROSE. TODOS LOS DERECHOS RESERVADOS.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--negro-suave);
    border-top: 1px solid var(--borde);
    padding: 6rem 5% 3rem;
    margin-top: 15rem;
  }

  .footer-container {
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    align-items: center;
    justify-items: center;
  }

  .footer-logo {
    justify-self: start;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .footer-links a {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    color: var(--gris);
  }

  .footer-links a:hover {
    color: var(--rojo);
  }

  .footer-copyright {
    justify-self: end;
    text-align: right;
  }

  .footer-copyright p {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 4rem 3% 2rem;
      margin-top: 10rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      gap: 1rem;
    }

    .logo-img {
      height: 40px;
    }
  }
</style>
