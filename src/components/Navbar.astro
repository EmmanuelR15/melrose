---
// Navbar with mobile hamburger menu
---

<nav class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="/" class="brand">
      <span class="logo-neon">MELROSE</span>
    </a>
    
    <div class="nav-links" id="navLinks">
      <div class="nav-links-backdrop"></div>
      <div class="nav-links-content">
        <a href="/#productos" data-category="TODO">SHOP</a>
        <a href="/#lookbook">LOOKBOOK</a>
        <a href="/#nosotros">NOSOTROS</a>
        <a href="/#ubicacion">CONTACTO</a>
        <a href="/favoritos" class="nav-link-wishlist">
          FAVORITOS
          <span class="wishlist-badge" id="wishlistBadge">0</span>
        </a>
      </div>
    </div>

    <div class="nav-right">
      <button class="cart-btn" id="cartOpenBtn" aria-label="Abrir carrito">
        <span class="cart-icon">BAG</span>
        <span class="cart-badge" id="cartBadge">0</span>
      </button>

      <button class="hamburger" id="hamburger" aria-label="Abrir menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile overlay -->
<div class="nav-overlay" id="navOverlay"></div>

<script>
  // Hamburger menu toggle with Astro View Transitions support
  document.addEventListener('astro:page-load', () => {
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    const navOverlay = document.getElementById('navOverlay');

    function closeMenu() {
      navLinks?.classList.remove('active');
      hamburger?.classList.remove('active');
      navOverlay?.classList.remove('active');
      document.body.style.overflow = '';
      console.log("🍔 Mobile Menu: Closed");
    }

    function openMenu() {
      navLinks?.classList.add('active');
      hamburger?.classList.add('active');
      navOverlay?.classList.add('active');
      document.body.style.overflow = 'hidden';
      console.log("🍔 Mobile Menu: Open");
    }

    if (hamburger && navLinks) {
      hamburger.addEventListener('click', (e) => {
        e.stopPropagation();
        if (navLinks.classList.contains('active')) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      // Close menu when link clicked
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => closeMenu());
      });
    }

    // Close on overlay click
    navOverlay?.addEventListener('click', () => closeMenu());

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  });

  // Escuchar actualización del carrito (Global, fuera del lifecycle de transición si es necesario)
  window.addEventListener('cartUpdated', (e) => {
    const badge = document.getElementById('cartBadge');
    if (badge) {
      badge.textContent = e.detail.cart.reduce((sum, item) => sum + parseInt(item.quantity || 0), 0);
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: 
      linear-gradient(180deg, 
        rgba(10, 10, 10, 0.98), 
        rgba(10, 10, 10, 0.95)
      );
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(0, 212, 255, 0.15);
    padding: 1rem 0;
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.08);
  }

  .navbar-container {
    max-width: 100%;
    padding: 0 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 40px;
    z-index: 1001;
    transition: all 0.3s ease;
  }

  .logo-neon {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: #ffffff;
    letter-spacing: 0.15em;
    text-shadow:
      0 0 5px rgba(192, 57, 43, 0.8),
      0 0 10px rgba(192, 57, 43, 0.6),
      0 0 20px rgba(192, 57, 43, 0.4),
      0 0 40px rgba(192, 57, 43, 0.2);
    transition: text-shadow 0.3s ease;
  }

  .logo-neon:hover {
    text-shadow:
      0 0 5px rgba(192, 57, 43, 1),
      0 0 15px rgba(192, 57, 43, 0.8),
      0 0 30px rgba(192, 57, 43, 0.6),
      0 0 60px rgba(192, 57, 43, 0.3);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 1001;
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .nav-links-backdrop {
    display: none;
  }

  .nav-links-content {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    position: relative;
    font-weight: 600;
  }

  .nav-links a::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--rojo);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::before {
    width: 100%;
  }

  .cart-btn {
    position: relative;
    background: transparent;
    border: none;
    color: var(--blanco);
    padding: 0.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-link-wishlist {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .wishlist-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: var(--rojo);
    color: var(--blanco);
    font-size: 0.6rem;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 8px;
    min-width: 16px;
    text-align: center;
    display: none;
  }

  .cart-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--rojo);
    color: var(--blanco);
    font-size: 0.7rem;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    margin-left: 4px;
  }

  .nav-links a:hover {
    color: var(--rojo);
    text-shadow: 0 0 8px rgba(192, 57, 43, 0.3);
  }

  /* Hamburger button */
  .hamburger {
    display: none;
    flex-direction: column;
    background: transparent;
    border: none;
    cursor: pointer;
    gap: 5px;
    z-index: 2001;
    padding: 4px;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background: var(--blanco);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: block;
    border-radius: 1px;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
    background: var(--rojo);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
    background: var(--rojo);
  }

  /* Mobile overlay */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    z-index: 1999;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .nav-overlay.active {
    display: block;
    opacity: 1;
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .navbar-container {
      padding: 0 4%;
    }

    .hamburger {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: 280px;
      height: 100vh;
      height: 100dvh;
      background: none;
      backdrop-filter: none;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      z-index: 2000;
      display: block; /* Change from flex to block to contain sibling anchors */
      border-left: none;
      isolation: isolate;
    }

    .nav-links-backdrop {
      display: block;
      position: absolute;
      inset: 0;
      background: rgba(10, 10, 10, 0.96);
      backdrop-filter: blur(15px);
      z-index: 1;
      border-left: 1px solid var(--borde);
      pointer-events: none;
    }

    .nav-links-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      padding: 6rem 2rem 2rem;
      width: 100%;
      height: 100%;
      gap: 0;
      align-items: flex-start;
    }

    .nav-links.active {
      transform: translateX(0);
    }

    .nav-links-content a {
      font-size: 1rem;
      letter-spacing: 0.15em;
      padding: 1rem 0;
      width: 100%;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      transition: all 0.3s ease;
      color: var(--blanco); /* Ensure color is solid */
      text-decoration: none;
    }

    .nav-links-content a:hover {
      padding-left: 1rem;
      color: var(--rojo);
    }
  }
</style>
