---
// Navbar with mobile hamburger menu
---

<nav class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="/" class="brand">
      <span class="logo-neon">MELROSE</span>
    </a>
    
    <div class="nav-links" id="navLinks">
      <a href="#productos">SHOP</a>
      <a href="#lookbook">LOOKBOOK</a>
      <a href="#nosotros">NOSOTROS</a>
      <a href="/favoritos" class="nav-link-wishlist">
        FAVORITOS
        <span class="wishlist-badge" id="wishlistBadge">0</span>
      </a>
    </div>

    <button class="cart-btn" id="cartOpenBtn" aria-label="Abrir carrito">
      <span class="cart-icon">BAG</span>
      <span class="cart-badge" id="cartBadge">0</span>
    </button>
  </div>
</nav>

<script>
  // Hamburger menu toggle
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');

  if (hamburger && navLinks) {
    hamburger.addEventListener('click', () => {
      navLinks.classList.toggle('active');
      hamburger.classList.toggle('active');
    });

    // Close menu when link clicked
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        hamburger.classList.remove('active');
      });
    });
  }
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: 
      linear-gradient(180deg, 
        rgba(10, 10, 10, 0.98), 
        rgba(10, 10, 10, 0.95)
      );
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(0, 212, 255, 0.15);
    padding: 1rem 0;
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.08);
  }

  .navbar-container {
    max-width: 100%;
    padding: 0 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 40px;
    z-index: 1001;
    transition: all 0.3s ease;
  }

  .logo-neon {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: #ffffff;
    letter-spacing: 0.15em;
    text-shadow:
      0 0 5px rgba(192, 57, 43, 0.8),
      0 0 10px rgba(192, 57, 43, 0.6),
      0 0 20px rgba(192, 57, 43, 0.4),
      0 0 40px rgba(192, 57, 43, 0.2);
    transition: text-shadow 0.3s ease;
  }

  .logo-neon:hover {
    text-shadow:
      0 0 5px rgba(192, 57, 43, 1),
      0 0 15px rgba(192, 57, 43, 0.8),
      0 0 30px rgba(192, 57, 43, 0.6),
      0 0 60px rgba(192, 57, 43, 0.3);
  }

  .nav-links {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    position: relative;
    font-weight: 600;
  }

  .nav-links a::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--rojo);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::before {
    width: 100%;
  }

  .cart-btn {
    position: relative;
    background: transparent;
    border: none;
    color: var(--blanco);
    padding: 0.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-link-wishlist {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .wishlist-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: var(--rojo);
    color: var(--blanco);
    font-size: 0.6rem;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 8px;
    min-width: 16px;
    text-align: center;
    display: none;
  }

  .cart-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes floatBag {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .cart-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--rojo);
    color: var(--blanco);
    font-size: 0.7rem;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    margin-left: 4px;
  }

  .nav-links a:hover {
    color: var(--rojo);
    text-shadow: 0 0 8px rgba(192, 57, 43, 0.3);
  }

  .admin-link {
    color: var(--rojo);
    border: 1px solid var(--rojo);
    transition: all 0.3s ease;
    box-shadow: 
      inset 0 0 10px rgba(192, 57, 43, 0.1),
      0 0 10px rgba(192, 57, 43, 0.2);
  }

  .admin-link:hover {
    background: var(--rojo);
    color: var(--blanco);
    text-shadow: none;
    box-shadow: 
      0 0 20px rgba(192, 57, 43, 0.6),
      inset 0 0 10px rgba(192, 57, 43, 0.3);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    background: transparent;
    border: none;
    cursor: pointer;
    gap: 5px;
    z-index: 1001;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background: var(--rojo);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: block;
    box-shadow: 0 0 10px rgba(192, 57, 43, 0.4);
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
    box-shadow: 0 0 10px rgba(192, 57, 43, 0.6);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -8px);
    box-shadow: 0 0 10px rgba(192, 57, 43, 0.6);
  }

  @media (max-width: 768px) {
    .navbar-container {
      padding: 0 3%;
    }

    .hamburger {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 70px;
      left: 0;
      right: 0;
      background: 
        linear-gradient(180deg, 
          rgba(10, 10, 10, 0.98), 
          rgba(20, 20, 20, 0.95)
        );
      flex-direction: column;
      gap: 1rem;
      padding: 2rem;
      transform: translateX(-100%);
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      border-bottom: 1px solid rgba(0, 212, 255, 0.15);
      backdrop-filter: blur(8px);
    }

    .nav-links.active {
      transform: translateX(0);
    }

    .nav-links a {
      font-size: 0.75rem;
      padding: 0.5rem 0;
    }

    .nav-links a::before {
      display: none;
    }

    .nav-links a:hover {
      padding-left: 1rem;
    }

  }
</style>
