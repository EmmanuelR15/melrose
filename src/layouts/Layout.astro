---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Cart from '../components/Cart.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "STW - E-commerce Editorial de Alta Gama" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png?v=6" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- SEO Meta Tags -->
		<meta name="keywords" content="streetwear, moda urbana, ropa premium, melrose, argentina, e-commerce, remeras, buzos, pantalones, accesorios" />
		<meta name="author" content="MELROSE" />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://melrose-stw.com" />
		<meta property="og:image" content="https://melrose-stw.com/images/og-image.jpg" />
		<meta property="og:site_name" content="MELROSE" />
		<meta property="og:locale" content="es_AR" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://melrose-stw.com/images/og-image.jpg" />
		<meta name="theme-color" content="#0a0a0a" />
		<link rel="canonical" href="https://melrose-stw.com" />

		<!-- Fuentes -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<ClientRouter />

		<script>
			import { initAnimations } from '../scripts/animations';

			// Scroll reset on page reload (F5)
			if (performance.navigation.type === 1) {
				window.scrollTo(0, 0);
			}

			// Inicialización inicial
			document.addEventListener('DOMContentLoaded', () => {
				initAnimations();
			});

			// Reinicialización después de transiciones de página
			document.addEventListener('astro:after-swap', () => {
				initAnimations();
			});
		</script>
		
		<!-- Wishlist Management -->
		<script src="/scripts/wishlist.js" type="module"></script>
	</head>
	<body>
		<Navbar />
		<Cart />
		<slot />
		<Footer />
		
		<style is:global>
			/* Optimizaciones para View Transitions */
			::view-transition-old(root),
			::view-transition-new(root) {
				animation-duration: 0.5s;
			}
		</style>
	</body>
</html>
